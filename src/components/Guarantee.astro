---
// Guarantee.astro
// Section 06 — Results or You Don't Pay. That's the Offer.
// DNA: High-contrast full-width statement section, two guarantee blocks
// Different visual treatment — dark surface bg to break page rhythm
// Content from: content-homepage-dominion-digital.md → Guarantee section
---

<section
  style="padding-top: clamp(8rem, 14vw, 14rem); padding-bottom: clamp(8rem, 14vw, 14rem); background: #161614; position: relative; overflow: hidden;"
  aria-labelledby="guarantee-heading"
  id="guarantee"
>
  <!-- Pulsing radial bloom — centered behind content -->
  <div aria-hidden="true" style="position: absolute; inset: 0; pointer-events: none; z-index: 0;">
    <div class="guarantee-bloom" style="position: absolute; width: 900px; height: 900px; border-radius: 50%; left: 50%; top: 50%; margin-left: -450px; margin-top: -450px; background: radial-gradient(circle, rgba(200,81,26,0.38) 0%, transparent 65%); filter: blur(60px);"></div>
  </div>

  <div class="container" style="position: relative; z-index: 1;">

    <!-- Header -->
    <div class="reveal" id="guarantee-header">

      <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
        05
      </p>

      <h2
        id="guarantee-heading"
        class="font-display font-bold tracking-tight text-text mb-8"
        style="font-size: clamp(2rem, 4vw, 3.5rem); max-width: 28ch;"
      >
        Results or You Don't Pay.<br class="hidden md:block" />
        That's the Offer.
      </h2>

      <p class="font-body leading-relaxed text-text-muted mb-16 md:mb-20" style="font-size: 1.125rem; max-width: 52ch;">
        Most marketing agencies are better at presenting data than generating revenue. If the best answer your agency can give to "are we getting leads?" is "your organic impressions are up 18%," that's not an answer. Every service <strong style="color: #f0ebe1; font-weight: 800;">Dominion</strong><span style="color: #c8511a;">.</span><span style="color: #f0ebe1; font-weight: 400;">Digital</span> runs gets measured against one standard: did your pipeline grow?
      </p>

    </div>

    <!-- Two guarantee blocks -->
    <div class="reveal grid grid-cols-1 md:grid-cols-2" id="guarantee-blocks" style="gap: 1.25rem; margin-top: 2rem; margin-bottom: 2rem;">

      <!-- Site Guarantee -->
      <div class="guarantee-card" style="padding: clamp(2.5rem, 5vw, 3.5rem);">

        <p class="font-label text-xs tracking-widest uppercase mb-6" style="color: #8a8880;">
          The Website Guarantee
        </p>

        <p
          class="font-display font-bold tracking-tight text-text mb-6"
          style="font-size: clamp(1.5rem, 2.5vw, 2rem);"
        >
          Love it or you don't pay.
        </p>

        <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
          If you're not satisfied with your website at any point during the build, you get every dollar back. No questions. We don't launch until you'd be proud to send that URL to your best client.
        </p>

      </div>

      <!-- Results Guarantee -->
      <div class="guarantee-card" style="padding: clamp(2.5rem, 5vw, 3.5rem);">

        <p class="font-label text-xs tracking-widest uppercase mb-6" style="color: #8a8880;">
          The Results Guarantee
        </p>

        <p
          class="font-display font-bold tracking-tight mb-6"
          style="font-size: clamp(1.5rem, 2.5vw, 2rem); color: #c8511a;"
        >
          Results or you don't pay.
        </p>

        <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
          If you don't have more qualified leads coming in within 90 days of launch, we keep working at no charge for up to 90 more days until you do. Seriously. We care about results that much.
        </p>

      </div>

    </div>

    <!-- Closing statement + CTA -->
    <div class="reveal mt-16 md:mt-20 flex flex-col md:flex-row md:items-center md:justify-between gap-8" id="guarantee-cta">

      <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem; max-width: 52ch;">
        The Kansas City business owners who work best with <strong style="color: #f0ebe1; font-weight: 800;">Dominion</strong><span style="color: #c8511a;">.</span><span style="color: #f0ebe1; font-weight: 400;">Digital</span> are the ones who've been burned before. They're not looking for promises. They're looking for an agency willing to put skin in the game.
      </p>

      <button
        type="button"
        data-open-contact
        class="btn-cta inline-flex items-center shrink-0 font-label font-semibold tracking-widest uppercase text-text bg-accent hover:bg-accent-hover active:scale-[0.97]"
        style="font-size: 0.7rem; padding: 0.6rem 1.25rem;"
      >
        Get Started
      </button>

    </div>

  </div>
</section>

<style>
  @keyframes guarantee-bloom-pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50%       { opacity: 1;   transform: scale(1.18); }
  }
  .guarantee-bloom {
    animation: guarantee-bloom-pulse 10s ease-in-out infinite;
  }

  .guarantee-card {
    border-radius: 1rem;
    background: rgba(22, 22, 20, 0.55);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(240, 235, 225, 0.1);
    transition: transform 700ms ease, box-shadow 700ms ease;
  }
  .guarantee-card:hover {
    transform: scale(1.025);
    box-shadow: 0 0 0 1px rgba(200, 81, 26, 0.25), 0 0 30px rgba(200, 81, 26, 0.2), 0 0 60px rgba(200, 81, 26, 0.1);
  }
</style>

<script>
  ['guarantee-header', 'guarantee-blocks', 'guarantee-cta'].forEach((id, i) => {
    const el = document.getElementById(id);
    if (!el) return;
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          setTimeout(() => el.classList.add('visible'), i * 150);
          observer.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    observer.observe(el);
  });
</script>
