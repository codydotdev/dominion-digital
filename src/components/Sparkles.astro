<canvas
  data-sparkles
  aria-hidden="true"
  style="position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 0;"
></canvas>

<script>
  document.querySelectorAll<HTMLCanvasElement>('canvas[data-sparkles]').forEach((canvas) => {
    const ctx = canvas.getContext('2d')!;
    let particles: Particle[] = [];
    let raf: number;
    let mouse = { x: -9999, y: -9999 };
    const REPULSE_RADIUS = 90;
    const REPULSE_STRENGTH = 0.1;

    interface Particle {
      x: number; y: number;
      size: number;
      opacity: number;
      targetOpacity: number;
      fadeSpeed: number;
      vx: number; vy: number;
      baseVx: number; baseVy: number;
      color: string;
    }

    function rand(min: number, max: number) {
      return Math.random() * (max - min) + min;
    }

    function make(): Particle {
      const vx = rand(-0.12, 0.12);
      const vy = rand(-0.12, 0.12);
      return {
        x: Math.random() * canvas.width,
        y: Math.random() * canvas.height,
        size: rand(0.5, 2.2),
        opacity: Math.random(),
        targetOpacity: Math.random(),
        fadeSpeed: rand(0.003, 0.01),
        vx, vy,
        baseVx: vx, baseVy: vy,
        color: Math.random() > 0.88 ? '#c8511a' : '#f0ebe1',
      };
    }

    function init() {
      canvas.width = canvas.offsetWidth;
      canvas.height = canvas.offsetHeight;
      particles = Array.from({ length: 132 }, make);
    }

    function tick() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);

      for (const p of particles) {
        // Fade
        if (Math.abs(p.opacity - p.targetOpacity) < p.fadeSpeed) {
          p.targetOpacity = Math.random();
        } else {
          p.opacity += p.opacity < p.targetOpacity ? p.fadeSpeed : -p.fadeSpeed;
        }

        // Mouse repulsion
        const dx = p.x - mouse.x;
        const dy = p.y - mouse.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < REPULSE_RADIUS && dist > 0) {
          const force = (REPULSE_RADIUS - dist) / REPULSE_RADIUS;
          p.vx += (dx / dist) * force * REPULSE_STRENGTH;
          p.vy += (dy / dist) * force * REPULSE_STRENGTH;
        }

        // Drift back toward base velocity
        p.vx += (p.baseVx - p.vx) * 0.02;
        p.vy += (p.baseVy - p.vy) * 0.02;

        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0) p.x = canvas.width;
        if (p.x > canvas.width) p.x = 0;
        if (p.y < 0) p.y = canvas.height;
        if (p.y > canvas.height) p.y = 0;

        ctx.beginPath();
        ctx.arc(p.x, p.y, p.size, 0, Math.PI * 2);
        ctx.fillStyle = p.color;
        ctx.globalAlpha = Math.max(0, Math.min(1, p.opacity));
        ctx.fill();
      }

      ctx.globalAlpha = 1;
      raf = requestAnimationFrame(tick);
    }

    init();
    tick();

    function updateMouse(clientX: number, clientY: number) {
      const rect = canvas.getBoundingClientRect();
      mouse.x = clientX - rect.left;
      mouse.y = clientY - rect.top;
    }

    window.addEventListener('mousemove', (e) => updateMouse(e.clientX, e.clientY));

    window.addEventListener('mouseleave', () => {
      mouse.x = -9999;
      mouse.y = -9999;
    });

    window.addEventListener('touchmove', (e) => {
      const t = e.touches[0];
      updateMouse(t.clientX, t.clientY);
    }, { passive: true });

    window.addEventListener('touchend', () => {
      mouse.x = -9999;
      mouse.y = -9999;
    });

    window.addEventListener('resize', () => {
      cancelAnimationFrame(raf);
      init();
      tick();
    });
  });
</script>
