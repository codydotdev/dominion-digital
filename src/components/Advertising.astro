---
// Advertising.astro
// Section 03 — Paid Ads That Produce Leads, Not Just Clicks
// DNA: 2-col asymmetric (3fr 2fr), left body copy, right services + CTA
// SEO anchor: "Advertising Agency" in opening sentence
// Content from: content-homepage-dominion-digital.md → Advertising section
---

<section
  style="padding-top: clamp(8rem, 14vw, 14rem); padding-bottom: clamp(8rem, 14vw, 14rem);"
  aria-labelledby="advertising-heading"
  id="advertising"
>
  <div class="container">

    <div class="grid grid-cols-1 md:grid-cols-[3fr_2fr] items-start gap-16 md:gap-24">

      <!-- Left: narrative copy -->
      <div class="reveal" id="advertising-copy">

        <!-- Section number -->
        <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
          03
        </p>

        <!-- H2 -->
        <h2
          id="advertising-heading"
          class="font-display font-bold tracking-tight text-text mb-10"
          style="font-size: clamp(2rem, 4vw, 3.5rem);"
        >
          Paid Ads That Produce<br class="hidden md:block" />
          Leads, Not Just Clicks.
        </h2>

        <!-- Body paragraphs — SEO anchor "Advertising Agency" in opening sentence -->
        <div class="space-y-6 max-w-2xl">

          <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
            Every advertising agency in Kansas City will tell you their ads work. Business owners have heard that before. They hand over $2,000 a month, watch the budget disappear, and get back a report full of clicks that never turned into customers.
          </p>

          <p class="font-body leading-relaxed text-text" style="font-size: 1.125rem;">
            The platform is rarely the problem. Google Ads work. The problem is strategy, targeting, and copy. Most agencies optimize for clicks. <strong style="font-weight: 800; color: #f0ebe1;">Dominion</strong><span style="color: #c8511a;">.</span><span style="font-weight: 400; color: #f0ebe1;">Digital</span> optimizes for <span style="color: #c8511a; font-weight: 500;">cost-per-lead.</span> Those are different goals that produce very different results.
          </p>

          <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
            Every campaign includes conversion tracking from day one. Your reporting shows exactly where your budget went and exactly how many leads it produced. No brand awareness charts. No reach metrics. Pipeline.
          </p>

          <p class="font-body leading-relaxed text-text" style="font-size: 1.125rem;">
            How much should you spend on Google Ads in Kansas City? Most local service businesses see positive return on ad spend with a monthly budget between $1,500 and $5,000. The right number depends on your average job value, your service area, and your current conversion rate. We'll tell you the honest number before you spend a dollar.
          </p>

        </div>

      </div>

      <!-- Right: services list + CTA -->
      <div class="reveal flex flex-col" id="advertising-services">

        <!-- Services label -->
        <p class="font-label text-xs tracking-widest uppercase mb-6" style="color: #8a8880;">
          Advertising Services
        </p>

        <!-- Services list -->
        <ul class="stagger mb-10" aria-label="Advertising services offered">
          <li class="font-body text-text py-4 border-t" style="font-size: 1rem; border-color: rgba(240,235,225,0.08);">
            <a href="/advertising/google-ads-management" class="flex items-center justify-between hover:text-accent transition-colors duration-200" style="text-decoration: none; color: inherit;">
              Google Ads Management
              <svg style="width: 0.75rem; height: 0.75rem; flex-shrink: 0; opacity: 0.4;" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </li>
          <li class="font-body text-text py-4 border-t" style="font-size: 1rem; border-color: rgba(240,235,225,0.08);">
            <a href="/advertising/ad-copywriting" class="flex items-center justify-between hover:text-accent transition-colors duration-200" style="text-decoration: none; color: inherit;">
              Ad Copywriting &amp; Creative
              <svg style="width: 0.75rem; height: 0.75rem; flex-shrink: 0; opacity: 0.4;" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </li>
          <li class="font-body text-text py-4 border-t" style="font-size: 1rem; border-color: rgba(240,235,225,0.08);">
            <a href="/advertising/ppc-campaign-strategy" class="flex items-center justify-between hover:text-accent transition-colors duration-200" style="text-decoration: none; color: inherit;">
              PPC Campaign Strategy
              <svg style="width: 0.75rem; height: 0.75rem; flex-shrink: 0; opacity: 0.4;" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </li>
          <li class="font-body text-text py-4 border-t" style="font-size: 1rem; border-color: rgba(240,235,225,0.08);">
            <a href="/advertising/meta-ads" class="flex items-center justify-between hover:text-accent transition-colors duration-200" style="text-decoration: none; color: inherit;">
              Meta Ads Management
              <svg style="width: 0.75rem; height: 0.75rem; flex-shrink: 0; opacity: 0.4;" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </li>
          <li class="py-4 border-t border-b" style="border-color: rgba(240,235,225,0.08);"></li>
        </ul>

        <!-- CTA -->
        <button
          type="button"
          data-open-contact
          class="btn-cta inline-flex items-center self-start font-label font-semibold tracking-widest uppercase text-text bg-accent hover:bg-accent-hover active:scale-[0.97]"
          style="font-size: 0.7rem; padding: 0.6rem 1.25rem; margin-top: 2.5rem;"
        >
          Get Started
        </button>

      </div>

    </div>

  </div>
</section>

<script>
  ['advertising-copy', 'advertising-services'].forEach((id, i) => {
    const el = document.getElementById(id);
    if (!el) return;
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          setTimeout(() => el.classList.add('visible'), i * 120);
          observer.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    observer.observe(el);
  });

  (function () {
    const services = document.getElementById('advertising-services');
    const section  = document.getElementById('advertising');
    if (!services || !section) return;
    // Kill transform transition immediately — prevents CSS easing from fighting JS updates
    services.style.transition = 'opacity 600ms ease-out';
    let raf: number | null = null;
    function tick() {
      if (window.innerWidth < 768) {
        services.style.transform = '';
        raf = null;
        return;
      }
      const top  = section.getBoundingClientRect().top;
      const vh   = window.innerHeight;
      const past = Math.max(0, vh * 0.5 - top);
      const max  = Math.max(0, section.offsetHeight - services.offsetHeight - 80);
      services.style.transform = `translateY(${Math.min(past * 0.35, max)}px)`;
      raf = null;
    }
    window.addEventListener('scroll', () => { if (!raf) raf = requestAnimationFrame(tick); }, { passive: true });
    window.addEventListener('resize', () => { if (!raf) raf = requestAnimationFrame(tick); }, { passive: true });
  })();
</script>
