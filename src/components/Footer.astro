---
// Footer.astro
// DNA: Full-width, slightly deeper bg (#0a0a09), 4-col desktop grid
// border-top subtle, minimal — no decorative elements
// Logo + tagline | Services | Company | Contact CTA
---

<footer
  style="background: #0a0a09; border-top: 1px solid rgba(240,235,225,0.08);"
  aria-label="Site footer"
>
  <div class="container" style="padding-top: 5rem; padding-bottom: 5rem;">

    <div class="grid grid-cols-2 md:grid-cols-[2fr_1fr_1fr_2fr]" style="gap: clamp(2rem, 4vw, 3rem);">

      <!-- Col 1: Logo + tagline -->
      <div>
        <a href="/" class="inline-flex items-center" style="gap: 0.75rem; margin-bottom: 1.25rem;" aria-label="Dominion.Digital home">
          <img
            src="/images/Dominion Digital Logo White.png"
            alt="Dominion.Digital logo"
            style="height: 28px; width: auto; display: block;"
          />
          <span class="font-wordmark text-text" style="font-size: 0.875rem; letter-spacing: 0.06em; text-transform: uppercase; white-space: nowrap;">
            <strong style="font-weight: 800;">DOMINION</strong><span style="color: #c8511a;">.</span><span style="font-weight: 400;">DIGITAL</span>
          </span>
        </a>
        <p class="font-body text-text-muted leading-relaxed" style="font-size: 0.9rem; max-width: 26ch;">
          Kansas City Digital Marketing. Dominate your market.
        </p>
      </div>

      <!-- Col 2: Services -->
      <div>
        <p class="font-label text-xs tracking-widest uppercase" style="color: #8a8880; margin-bottom: 1.25rem;">
          Services
        </p>
        <ul style="display: flex; flex-direction: column; gap: 0.75rem;">
          <li><a href="/web-design"        class="footer-link font-body text-text-muted hover:text-text transition-colors duration-200" style="font-size: 0.9rem;">Web Design</a></li>
          <li><a href="/internet-marketing" class="footer-link font-body text-text-muted hover:text-text transition-colors duration-200" style="font-size: 0.9rem;">SEO &amp; GEO</a></li>
          <li><a href="/advertising"       class="footer-link font-body text-text-muted hover:text-text transition-colors duration-200" style="font-size: 0.9rem;">Google Ads</a></li>
          <li><a href="/ai-automation"     class="footer-link font-body text-text-muted hover:text-text transition-colors duration-200" style="font-size: 0.9rem;">AI Automation</a></li>
        </ul>
      </div>

      <!-- Col 3: Company -->
      <div>
        <p class="font-label text-xs tracking-widest uppercase" style="color: #8a8880; margin-bottom: 1.25rem;">
          Company
        </p>
        <ul style="display: flex; flex-direction: column; gap: 0.75rem;">
          <li><a href="/about"   class="footer-link font-body text-text-muted hover:text-text transition-colors duration-200" style="font-size: 0.9rem;">About</a></li>
          <li><a href="/pricing" class="footer-link font-body text-text-muted hover:text-text transition-colors duration-200" style="font-size: 0.9rem;">Pricing</a></li>
          <li><a href="/contact" class="footer-link font-body text-text-muted hover:text-text transition-colors duration-200" style="font-size: 0.9rem;">Contact</a></li>
        </ul>
      </div>

      <!-- Col 4: CTA block -->
      <div class="md:text-right">
        <p class="font-label text-xs tracking-widest uppercase" style="color: #8a8880; margin-bottom: 1.25rem;">
          Ready to Grow?
        </p>
        <p class="font-body text-text-muted leading-relaxed" style="font-size: 0.9rem; margin-bottom: 1.5rem;">
          More qualified leads in 90 days or we work for free. <span style="color: #f0ebe1;">Guaranteed.</span>
        </p>
        <button
          type="button"
          data-open-contact
          class="btn-cta inline-flex items-center font-label font-semibold tracking-widest uppercase text-text bg-accent hover:bg-accent-hover active:scale-[0.97]"
          style="font-size: 0.7rem; padding: 0.6rem 1.25rem;"
        >
          Get Started
        </button>
      </div>

    </div>

    <!-- Bottom bar -->
    <div
      class="flex flex-col md:flex-row md:items-center md:justify-between"
      style="gap: 1rem; margin-top: 2rem; padding-top: 2rem; border-top: 1px solid rgba(240,235,225,0.06);"
    >
      <p class="font-body text-text-muted" style="font-size: 0.8rem;">
        &copy; 2026 dominion.digital. Kansas City, MO. All rights reserved.
      </p>
      <p class="font-body text-text-muted" style="font-size: 0.8rem;">
        dominion.digital
      </p>
    </div>

  </div>
</footer>
