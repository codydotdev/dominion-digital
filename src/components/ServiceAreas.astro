---
// ServiceAreas.astro
// Section 05 — Service Areas in Kansas City
// DNA: Full-width centered intro + typographic location grid below
// Different visual treatment from service sections — breaks the rhythm
// Content from: content-homepage-dominion-digital.md → Service Areas section
---

<section
  style="padding-top: clamp(8rem, 14vw, 14rem); padding-bottom: clamp(8rem, 14vw, 14rem);"
  aria-labelledby="areas-heading"
  id="service-areas"
>
  <div class="container">

    <!-- Top: section number + H2 + intro copy -->
    <div class="reveal" id="areas-header">

      <p class="font-label text-xs tracking-widest uppercase" style="color: #8a8880; margin-bottom: 1.25rem;">
        06
      </p>

      <div class="grid grid-cols-1 md:grid-cols-[3fr_2fr] items-end" style="gap: clamp(2rem, 6vw, 6rem);">

        <h2
          id="areas-heading"
          class="font-display font-bold tracking-tight text-text"
          style="font-size: clamp(2rem, 4vw, 3.5rem); margin-bottom: 2rem;"
        >
          Kansas City Roots.<br class="hidden md:block" />
          Nationwide Reach.
        </h2>

        <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
          <strong style="font-weight: 800; color: #f0ebe1;">Dominion</strong><span style="color: #c8511a;">.</span><span style="font-weight: 400; color: #f0ebe1;">Digital</span> is based in Kansas City and works with businesses across the metro on both sides of the state line. For businesses outside the KC metro, location doesn't change the process.
        </p>

      </div>

    </div>

    <!-- Location grid -->
    <div
      class="reveal"
      id="areas-grid"
      style="margin-top: clamp(3rem, 5vw, 5rem); border-top: 1px solid rgba(240,235,225,0.08);"
    >

      <div class="grid grid-cols-2 md:grid-cols-4">

        <div class="area-item font-body text-text" style="font-size: 1rem;">
          Kansas City, MO &amp; KS
        </div>
        <div class="area-item font-body text-text" style="font-size: 1rem;">
          Overland Park
        </div>
        <div class="area-item font-body text-text" style="font-size: 1rem;">
          Olathe
        </div>
        <div class="area-item font-body text-text" style="font-size: 1rem;">
          Lee's Summit
        </div>
        <div class="area-item font-body text-text" style="font-size: 1rem;">
          Independence
        </div>
        <div class="area-item font-body text-text" style="font-size: 1rem;">
          Liberty
        </div>
        <div class="area-item font-body text-text" style="font-size: 1rem;">
          Blue Springs
        </div>
        <div class="area-item font-body text-text" style="font-size: 1rem;">
          Shawnee
        </div>
        <div class="area-item font-body text-text" style="font-size: 1rem;">
          Leawood
        </div>
        <div class="area-item font-body text-text" style="font-size: 1rem;">
          Leavenworth
        </div>
        <div class="area-item font-body text-text" style="font-size: 1rem;">
          Parkville
        </div>
        <div class="area-item font-body text-text" style="font-size: 1rem;">
          Gladstone
        </div>
        <div class="area-item font-body text-text md:col-span-2" style="font-size: 1rem;">
          North Kansas City
        </div>
        <div
          class="area-item hidden md:flex items-center gap-2 font-label text-xs tracking-widest uppercase col-span-2"
          style="color: #c8511a;"
        >
          <span style="font-size: 0.65rem;">▲</span> Nationwide on Web Design, SEO &amp; Automation
        </div>

      </div>

    </div>

  </div>
</section>

<style>
  .area-item {
    padding: 1.25rem 0;
    border-bottom: 1px solid rgba(240,235,225,0.08);
    color: #8a8880;
    transition: color 200ms ease;
  }

  .area-item:hover {
    color: #f0ebe1;
  }
</style>

<script>
  ['areas-header', 'areas-grid'].forEach((id, i) => {
    const el = document.getElementById(id);
    if (!el) return;
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          setTimeout(() => el.classList.add('visible'), i * 150);
          observer.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    observer.observe(el);
  });
</script>
