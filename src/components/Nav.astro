---
// Nav.astro
// Floating frosted glass pill nav
// Desktop: hover dropdowns on each service category
// Mobile: accordion expand/collapse per category
---

<!-- Outer wrapper: fixed, full-width, centers the pill -->
<nav
  id="site-nav"
  class="fixed top-0 left-0 right-0 z-50 flex justify-center"
  style="padding: 0.75rem clamp(1rem, 3vw, 2rem) 0;"
  aria-label="Main navigation"
>

  <!-- The pill itself -->
  <div
    id="nav-pill"
    class="w-full grid items-center transition-all duration-300 ease-out"
    style="
      grid-template-columns: auto 1fr auto;
      max-width: 1100px;
      height: 56px;
      border-radius: 9999px;
      background: rgba(13, 13, 11, 0.45);
      backdrop-filter: blur(28px) saturate(160%);
      -webkit-backdrop-filter: blur(28px) saturate(160%);
      border: 1px solid rgba(240, 235, 225, 0.12);
      padding: 0 0.35rem 0 1.25rem;
      overflow: visible;
    "
  >

    <!-- Logo -->
    <a
      href="/"
      class="flex items-center gap-3 shrink-0 col-start-1"
      aria-label="Dominion.Digital home"
    >
      <img
        src="/images/Dominion Digital Logo White.png"
        alt="Dominion.Digital logo"
        class="nav-logo"
        style="height: 26px; width: auto; display: block;"
      />
      <span class="font-wordmark text-text" style="font-size: 0.875rem; letter-spacing: 0.06em; text-transform: uppercase; white-space: nowrap;">
        <strong style="font-weight: 800; color: #f0ebe1;">DOMINION</strong><span style="color: #c8511a;">.</span><span style="font-weight: 400; color: #f0ebe1;">DIGITAL</span>
      </span>
    </a>

    <!-- Desktop nav links with dropdowns -->
    <div class="hidden lg:flex items-stretch col-start-2 justify-self-center" style="gap: 0; height: 100%;">

      <!-- Web Design dropdown -->
      <div class="nav-dropdown-group" style="position: relative; display: flex; align-items: center;">
        <a href="/web-design" class="nav-cat-link" aria-haspopup="true">
          Web Design
          <svg class="nav-chevron" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <div class="nav-dropdown" role="menu" aria-label="Web Design services">
          <div class="nav-dropdown-inner">
            <a href="/web-design" class="nav-dropdown-category" role="menuitem">Web Design Overview</a>
            <div class="nav-dropdown-divider"></div>
            <a href="/web-design/high-conversion-web-design" class="nav-dropdown-item" role="menuitem">High-Conversion Web Design</a>
            <a href="/web-design/custom-web-development" class="nav-dropdown-item" role="menuitem">Custom Web Development</a>
            <a href="/web-design/landing-pages" class="nav-dropdown-item" role="menuitem">Landing Pages</a>
          </div>
        </div>
      </div>

      <!-- Internet Marketing dropdown -->
      <div class="nav-dropdown-group" style="position: relative; display: flex; align-items: center;">
        <a href="/internet-marketing" class="nav-cat-link" aria-haspopup="true">
          Marketing
          <svg class="nav-chevron" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <div class="nav-dropdown" role="menu" aria-label="Internet Marketing services">
          <div class="nav-dropdown-inner">
            <a href="/internet-marketing" class="nav-dropdown-category" role="menuitem">Marketing Overview</a>
            <div class="nav-dropdown-divider"></div>
            <a href="/internet-marketing/seo" class="nav-dropdown-item" role="menuitem">Search Engine Optimization</a>
            <a href="/internet-marketing/geo" class="nav-dropdown-item" role="menuitem">Generative Engine Optimization</a>
            <a href="/internet-marketing/content-marketing" class="nav-dropdown-item" role="menuitem">Content Marketing</a>
            <a href="/internet-marketing/local-lead-generation" class="nav-dropdown-item" role="menuitem">Local Lead Generation</a>
            <a href="/internet-marketing/email-marketing" class="nav-dropdown-item" role="menuitem">Email Marketing</a>
          </div>
        </div>
      </div>

      <!-- Advertising dropdown -->
      <div class="nav-dropdown-group" style="position: relative; display: flex; align-items: center;">
        <a href="/advertising" class="nav-cat-link" aria-haspopup="true">
          Advertising
          <svg class="nav-chevron" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <div class="nav-dropdown" role="menu" aria-label="Advertising services">
          <div class="nav-dropdown-inner">
            <a href="/advertising" class="nav-dropdown-category" role="menuitem">Advertising Overview</a>
            <div class="nav-dropdown-divider"></div>
            <a href="/advertising/google-ads-management" class="nav-dropdown-item" role="menuitem">Google Ads Management</a>
            <a href="/advertising/ad-copywriting" class="nav-dropdown-item" role="menuitem">Ad Copywriting &amp; Creative</a>
            <a href="/advertising/ppc-campaign-strategy" class="nav-dropdown-item" role="menuitem">PPC Campaign Strategy</a>
            <a href="/advertising/meta-ads" class="nav-dropdown-item" role="menuitem">Meta Ads Management</a>
          </div>
        </div>
      </div>

      <!-- AI & Automation dropdown -->
      <div class="nav-dropdown-group" style="position: relative; display: flex; align-items: center;">
        <a href="/ai-automation" class="nav-cat-link" aria-haspopup="true">
          AI &amp; Automation
          <svg class="nav-chevron" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <div class="nav-dropdown" role="menu" aria-label="AI &amp; Automation services">
          <div class="nav-dropdown-inner">
            <a href="/ai-automation" class="nav-dropdown-category" role="menuitem">AI &amp; Automations Overview</a>
            <div class="nav-dropdown-divider"></div>
            <a href="/ai-automation/ai-automation-systems" class="nav-dropdown-item" role="menuitem">AI Automation Systems</a>
            <a href="/ai-automation/ai-voice-agents" class="nav-dropdown-item" role="menuitem">AI Voice Agents</a>
            <a href="/ai-automation/ai-chatbots" class="nav-dropdown-item" role="menuitem">AI Chatbots</a>
            <a href="/ai-automation/ai-reputation-management" class="nav-dropdown-item" role="menuitem">AI Reputation Management</a>
            <a href="/ai-automation/lead-nurturing" class="nav-dropdown-item" role="menuitem">Lead Nurturing Automation</a>
            <a href="/ai-automation/crm-automation" class="nav-dropdown-item" role="menuitem">CRM Automation</a>
            <a href="/ai-automation/client-onboarding" class="nav-dropdown-item" role="menuitem">Client Onboarding Automation</a>
          </div>
        </div>
      </div>

    </div>

    <!-- CTA -->
    <div class="hidden min-[540px]:flex items-center max-lg:col-start-2 max-lg:justify-self-center lg:col-start-3 lg:justify-self-end">
      <button
        type="button"
        data-open-contact
        class="btn-cta inline-flex items-center font-label text-text bg-accent hover:bg-accent-hover active:scale-[0.97]"
        style="font-size: 0.7rem; font-weight: 600; letter-spacing: 0.1em; text-transform: uppercase; padding: 0.6rem 1.25rem;"
      >
        Get Started
      </button>
    </div>

    <!-- Mobile hamburger -->
    <button
      id="nav-toggle"
      class="lg:hidden flex flex-col justify-center bg-transparent border-none cursor-pointer p-1 col-start-3 justify-self-end"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
      style="width: 36px; height: 36px; gap: 5px;"
    >
      <span id="bar1" class="block bg-text transition-transform duration-300 ease-out" style="width: 22px; height: 1.5px;"></span>
      <span id="bar2" class="block bg-text transition-opacity duration-300 ease-out" style="width: 22px; height: 1.5px;"></span>
      <span id="bar3" class="block bg-text transition-transform duration-300 ease-out" style="width: 22px; height: 1.5px;"></span>
    </button>

  </div>
</nav>

<!-- Mobile menu panel -->
<div
  id="mobile-menu"
  class="fixed right-0 bottom-0 z-40 flex flex-col transition-transform duration-300 ease-out translate-x-full overflow-y-auto"
  style="top: 72px; width: 75%; max-width: 300px; background: rgba(22,22,20,0.96); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-left: 1px solid rgba(240,235,225,0.06); padding: 1.5rem 2rem 2rem; gap: 0;"
  aria-hidden="true"
>

  <!-- Web Design accordion -->
  <div class="mobile-nav-group">
    <div class="mobile-nav-row">
      <a href="/web-design" class="font-label text-text-muted hover:text-text transition-colors duration-200" style="font-size: 0.875rem; letter-spacing: 0.08em; text-transform: uppercase;">Web Design</a>
      <button class="mobile-nav-toggle" aria-expanded="false" aria-label="Expand Web Design services">
        <svg class="mobile-chevron" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
    <div class="mobile-nav-sub">
      <a href="/web-design/high-conversion-web-design" class="mobile-nav-sub-link">High-Conversion Web Design</a>
      <a href="/web-design/custom-web-development" class="mobile-nav-sub-link">Custom Web Development</a>
      <a href="/web-design/landing-pages" class="mobile-nav-sub-link">Landing Pages</a>
    </div>
  </div>

  <!-- Marketing accordion -->
  <div class="mobile-nav-group">
    <div class="mobile-nav-row">
      <a href="/internet-marketing" class="font-label text-text-muted hover:text-text transition-colors duration-200" style="font-size: 0.875rem; letter-spacing: 0.08em; text-transform: uppercase;">Marketing</a>
      <button class="mobile-nav-toggle" aria-expanded="false" aria-label="Expand Marketing services">
        <svg class="mobile-chevron" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
    <div class="mobile-nav-sub">
      <a href="/internet-marketing/seo" class="mobile-nav-sub-link">Search Engine Optimization</a>
      <a href="/internet-marketing/geo" class="mobile-nav-sub-link">Generative Engine Optimization</a>
      <a href="/internet-marketing/content-marketing" class="mobile-nav-sub-link">Content Marketing</a>
      <a href="/internet-marketing/local-lead-generation" class="mobile-nav-sub-link">Local Lead Generation</a>
      <a href="/internet-marketing/email-marketing" class="mobile-nav-sub-link">Email Marketing</a>
    </div>
  </div>

  <!-- Advertising accordion -->
  <div class="mobile-nav-group">
    <div class="mobile-nav-row">
      <a href="/advertising" class="font-label text-text-muted hover:text-text transition-colors duration-200" style="font-size: 0.875rem; letter-spacing: 0.08em; text-transform: uppercase;">Advertising</a>
      <button class="mobile-nav-toggle" aria-expanded="false" aria-label="Expand Advertising services">
        <svg class="mobile-chevron" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
    <div class="mobile-nav-sub">
      <a href="/advertising/google-ads-management" class="mobile-nav-sub-link">Google Ads Management</a>
      <a href="/advertising/ad-copywriting" class="mobile-nav-sub-link">Ad Copywriting &amp; Creative</a>
      <a href="/advertising/ppc-campaign-strategy" class="mobile-nav-sub-link">PPC Campaign Strategy</a>
      <a href="/advertising/meta-ads" class="mobile-nav-sub-link">Meta Ads Management</a>
    </div>
  </div>

  <!-- AI & Automation accordion -->
  <div class="mobile-nav-group">
    <div class="mobile-nav-row">
      <a href="/ai-automation" class="font-label text-text-muted hover:text-text transition-colors duration-200" style="font-size: 0.875rem; letter-spacing: 0.08em; text-transform: uppercase;">AI &amp; Automation</a>
      <button class="mobile-nav-toggle" aria-expanded="false" aria-label="Expand AI &amp; Automation services">
        <svg class="mobile-chevron" viewBox="0 0 10 6" fill="none" aria-hidden="true"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </button>
    </div>
    <div class="mobile-nav-sub">
      <a href="/ai-automation/ai-automation-systems" class="mobile-nav-sub-link">AI Automation Systems</a>
      <a href="/ai-automation/ai-voice-agents" class="mobile-nav-sub-link">AI Voice Agents</a>
      <a href="/ai-automation/ai-chatbots" class="mobile-nav-sub-link">AI Chatbots</a>
      <a href="/ai-automation/ai-reputation-management" class="mobile-nav-sub-link">AI Reputation Management</a>
      <a href="/ai-automation/lead-nurturing" class="mobile-nav-sub-link">Lead Nurturing Automation</a>
      <a href="/ai-automation/crm-automation" class="mobile-nav-sub-link">CRM Automation</a>
      <a href="/ai-automation/client-onboarding" class="mobile-nav-sub-link">Client Onboarding Automation</a>
    </div>
  </div>

  <!-- Get Started CTA (sub-540px only) -->
  <button
    type="button"
    data-open-contact
    class="btn-cta min-[540px]:hidden inline-flex items-center justify-center font-label text-text bg-accent hover:bg-accent-hover text-center tracking-widest uppercase transition-colors"
    style="font-size: 0.8rem; padding: 0.75rem 1rem; font-weight: 600; border-radius: 4px; margin-top: 0.5rem;"
  >
    Get Started
  </button>

</div>

<!-- Backdrop -->
<div
  id="nav-backdrop"
  class="fixed inset-0 z-30 opacity-0 pointer-events-none transition-opacity duration-300"
  style="background: rgba(13,13,11,0.6);"
></div>

<style>
  /* Logo spin on hover */
  .nav-logo {
    transition: transform 600ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  a:hover .nav-logo {
    transform: rotate(180deg);
  }

  /* ── Desktop category trigger ── */
  .nav-cat-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0 1rem;
    font-family: "Space Grotesk", system-ui, sans-serif;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8a8880;
    white-space: nowrap;
    transition: color 200ms ease;
    text-decoration: none;
  }
  .nav-cat-link:hover,
  .nav-dropdown-group:hover .nav-cat-link {
    color: #f0ebe1;
  }

  /* Chevron rotates on group hover */
  .nav-chevron {
    width: 8px;
    height: 5px;
    flex-shrink: 0;
    transition: transform 200ms ease;
  }
  .nav-dropdown-group:hover .nav-chevron {
    transform: rotate(180deg);
  }

  /* ── Desktop dropdown panel ── */
  .nav-dropdown {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(-6px);
    min-width: 220px;
    padding-top: 10px; /* invisible bridge — keeps hover alive crossing the gap */
    opacity: 0;
    pointer-events: none;
    transition: opacity 180ms ease-out, transform 180ms ease-out;
    z-index: 60;
  }
  .nav-dropdown-group:hover .nav-dropdown {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }
  /* visible box is a child so padding-top gap stays transparent */
  .nav-dropdown-inner {
    background: rgba(13, 13, 11, 0.97);
    backdrop-filter: blur(28px) saturate(160%);
    -webkit-backdrop-filter: blur(28px) saturate(160%);
    border: 1px solid rgba(240, 235, 225, 0.12);
    border-radius: 8px;
    padding: 0.5rem 0;
  }

  /* Category "overview" link at top of dropdown */
  .nav-dropdown-category {
    display: block;
    padding: 0.55rem 1.25rem;
    font-family: "Space Grotesk", system-ui, sans-serif;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #c8511a;
    text-decoration: none;
    transition: color 150ms ease;
    white-space: nowrap;
  }
  .nav-dropdown-category:hover {
    color: #e05e20;
  }

  .nav-dropdown-divider {
    height: 1px;
    background: rgba(240, 235, 225, 0.08);
    margin: 0.35rem 0;
  }

  /* Service links inside dropdown */
  .nav-dropdown-item {
    display: block;
    padding: 0.55rem 1.25rem;
    font-family: "DM Sans", system-ui, sans-serif;
    font-size: 0.85rem;
    font-weight: 400;
    color: #8a8880;
    text-decoration: none;
    transition: color 150ms ease, background 150ms ease;
    white-space: nowrap;
  }
  .nav-dropdown-item:hover {
    color: #f0ebe1;
    background: rgba(240, 235, 225, 0.04);
  }

  /* ── Mobile accordion ── */
  .mobile-nav-group {
    border-top: 1px solid rgba(240, 235, 225, 0.06);
  }

  .mobile-nav-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 0;
  }

  .mobile-nav-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    color: #8a8880;
    transition: color 200ms ease;
  }
  .mobile-nav-toggle:hover {
    color: #f0ebe1;
  }

  .mobile-chevron {
    width: 10px;
    height: 6px;
    transition: transform 250ms ease;
  }
  .mobile-nav-toggle[aria-expanded="true"] .mobile-chevron {
    transform: rotate(180deg);
  }

  /* Slide-open for sub-links */
  .mobile-nav-sub {
    overflow: hidden;
    max-height: 0;
    transition: max-height 280ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .mobile-nav-sub.is-open {
    max-height: 480px;
  }

  .mobile-nav-sub-link {
    display: block;
    padding: 0.55rem 0 0.55rem 1rem;
    font-family: "DM Sans", system-ui, sans-serif;
    font-size: 0.8rem;
    font-weight: 400;
    color: #8a8880;
    text-decoration: none;
    border-left: 1px solid rgba(200, 81, 26, 0.3);
    transition: color 150ms ease, border-color 150ms ease;
    margin-bottom: 0.1rem;
  }
  .mobile-nav-sub-link:hover {
    color: #f0ebe1;
    border-left-color: #c8511a;
  }
  /* breathing room below the sub-list */
  .mobile-nav-sub.is-open {
    padding-bottom: 0.75rem;
  }
</style>

<script>
  // ── Mobile menu open/close ──────────────────────────────────────────────────
  const toggle   = document.getElementById('nav-toggle')!;
  const menu     = document.getElementById('mobile-menu')!;
  const backdrop = document.getElementById('nav-backdrop')!;
  const bar1     = document.getElementById('bar1')!;
  const bar2     = document.getElementById('bar2')!;
  const bar3     = document.getElementById('bar3')!;

  let isOpen = false;

  function openMenu() {
    isOpen = true;
    menu.classList.remove('translate-x-full');
    backdrop.classList.remove('opacity-0', 'pointer-events-none');
    backdrop.classList.add('opacity-100', 'pointer-events-auto');
    toggle.setAttribute('aria-expanded', 'true');
    menu.setAttribute('aria-hidden', 'false');
    bar1.style.transform = 'rotate(45deg) translate(4.5px, 4.5px)';
    bar2.style.opacity = '0';
    bar3.style.transform = 'rotate(-45deg) translate(4.5px, -4.5px)';
    document.body.style.overflow = 'hidden';
  }

  function closeMenu() {
    isOpen = false;
    menu.classList.add('translate-x-full');
    backdrop.classList.add('opacity-0', 'pointer-events-none');
    backdrop.classList.remove('opacity-100', 'pointer-events-auto');
    toggle.setAttribute('aria-expanded', 'false');
    menu.setAttribute('aria-hidden', 'true');
    bar1.style.transform = '';
    bar2.style.opacity = '';
    bar3.style.transform = '';
    document.body.style.overflow = '';
  }

  toggle.addEventListener('click', () => isOpen ? closeMenu() : openMenu());
  backdrop.addEventListener('click', closeMenu);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && isOpen) closeMenu(); });

  // ── Mobile accordion toggles ────────────────────────────────────────────────
  document.querySelectorAll<HTMLButtonElement>('.mobile-nav-toggle').forEach(btn => {
    btn.addEventListener('click', () => {
      const group = btn.closest('.mobile-nav-group')!;
      const sub   = group.querySelector<HTMLElement>('.mobile-nav-sub')!;
      const open  = btn.getAttribute('aria-expanded') === 'true';

      if (open) {
        sub.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
      } else {
        sub.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
