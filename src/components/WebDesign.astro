---
// WebDesign.astro
// Section 02 — A Website That Actually Brings In Leads
// DNA: 2-col asymmetric (3fr 2fr), left body copy, right services + CTA
// SEO anchor: "Website Designer" in opening sentence of body
// Content from: content-homepage-dominion-digital.md → Web Design section
---

<section
  style="padding-top: clamp(8rem, 14vw, 14rem); padding-bottom: clamp(8rem, 14vw, 14rem);"
  aria-labelledby="webdesign-heading"
  id="web-design"
>
  <div class="container">

    <div class="grid grid-cols-1 md:grid-cols-[3fr_2fr] items-start gap-16 md:gap-24">

      <!-- Left: narrative copy -->
      <div class="reveal" id="webdesign-copy">

        <!-- Section number -->
        <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
          01
        </p>

        <!-- H2 -->
        <h2
          id="webdesign-heading"
          class="font-display font-bold tracking-tight text-text mb-10"
          style="font-size: clamp(2rem, 4vw, 3.5rem);"
        >
          Websites That Actually<br class="hidden md:block" /> Bring In Leads.
        </h2>

        <!-- Body paragraphs — SEO anchor "Website Designer" in opening sentence -->
        <div class="space-y-6 max-w-2xl">

          <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
            Most Kansas City businesses that hire a website designer end up with the same result: a site that looks fine, loads fast enough, and sits there doing nothing. A digital business card. You paid someone to build it, someone else to host it, and now it's competing with 40 other local businesses on a search page it barely shows up on.
          </p>

          <p class="font-body leading-relaxed text-text" style="font-size: 1.125rem;">
            A <strong style="font-weight: 800; color: #f0ebe1;">Dominion</strong><span style="color: #c8511a;">.</span><span style="font-weight: 400; color: #f0ebe1;">Digital</span> website is designed to convert. High-conversion architecture, fast load times, and a clear user journey with every page built to turn a visitor into a phone call or a form submission.
          </p>

          <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
            Local businesses across Kansas City have seen inbound contact double after a site rebuild. Get the website right and SEO, ads, and automation all perform better because of it.
          </p>

        </div>

      </div>

      <!-- Right: services list + CTA -->
      <div class="reveal flex flex-col" id="webdesign-services">

        <!-- Services label -->
        <p class="font-label text-xs tracking-widest uppercase mb-6" style="color: #8a8880;">
          Web Design Services
        </p>

        <!-- Services list: staggered reveal children -->
        <ul class="stagger mb-10" aria-label="Web design services offered">
          <li
            class="font-body text-text py-4 border-t"
            style="font-size: 1rem; border-color: rgba(240,235,225,0.08);"
          >
            <a href="/web-design/high-conversion-web-design" class="flex items-center justify-between hover:text-accent transition-colors duration-200" style="text-decoration: none; color: inherit;">
              High-Conversion Web Design
              <svg style="width: 0.75rem; height: 0.75rem; flex-shrink: 0; opacity: 0.4;" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </li>
          <li
            class="font-body text-text py-4 border-t"
            style="font-size: 1rem; border-color: rgba(240,235,225,0.08);"
          >
            <a href="/web-design/custom-web-development" class="flex items-center justify-between hover:text-accent transition-colors duration-200" style="text-decoration: none; color: inherit;">
              Custom Web Development
              <svg style="width: 0.75rem; height: 0.75rem; flex-shrink: 0; opacity: 0.4;" viewBox="0 0 12 12" fill="none" aria-hidden="true"><path d="M2 6h8M6 2l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </a>
          </li>
          <li
            class="py-4 border-t border-b"
            style="border-color: rgba(240,235,225,0.08);"
          >
            <!-- bottom border closer -->
          </li>
        </ul>

        <!-- CTA -->
        <button
          type="button"
          data-open-contact
          class="btn-cta inline-flex items-center self-start font-label font-semibold tracking-widest uppercase text-text bg-accent hover:bg-accent-hover active:scale-[0.97]"
          style="font-size: 0.7rem; padding: 0.6rem 1.25rem; margin-top: 2.5rem;"
        >
          Get Started
        </button>

      </div>

    </div>

  </div>
</section>

<script>
  // Section reveal
  ['webdesign-copy', 'webdesign-services'].forEach((id, i) => {
    const el = document.getElementById(id);
    if (!el) return;
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          setTimeout(() => el.classList.add('visible'), i * 120);
          observer.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    observer.observe(el);
  });

  // Slow-scroll parallax on services column
  // Trigger: when section midpoint crosses viewport center — Speed: 35% of page scroll
  (function () {
    const services = document.getElementById('webdesign-services');
    const section  = document.getElementById('web-design');
    if (!services || !section) return;
    // Kill transform transition immediately — prevents CSS easing from fighting JS updates
    services.style.transition = 'opacity 600ms ease-out';
    let raf: number | null = null;
    function tick() {
      if (window.innerWidth < 768) {
        services.style.transform = '';
        raf = null;
        return;
      }
      const top  = section.getBoundingClientRect().top;
      const vh   = window.innerHeight;
      const past = Math.max(0, vh * 0.5 - top);
      const max  = Math.max(0, section.offsetHeight - services.offsetHeight - 80);
      services.style.transform = `translateY(${Math.min(past * 0.35, max)}px)`;
      raf = null;
    }
    window.addEventListener('scroll', () => { if (!raf) raf = requestAnimationFrame(tick); }, { passive: true });
    window.addEventListener('resize', () => { if (!raf) raf = requestAnimationFrame(tick); }, { passive: true });
  })();
</script>
