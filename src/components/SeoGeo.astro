---
// SeoGeo.astro
// Section 02 — Rank on Google. Show Up in AI. Own Both.
// DNA: 2-col asymmetric (3fr 2fr), left body + 3-signs list, right services + CTA
// SEO anchor: "Internet Marketing Service" in opening sentence
// Content from: content-homepage-dominion-digital.md → SEO/GEO section
---

<section
  style="padding-top: clamp(8rem, 14vw, 14rem); padding-bottom: clamp(8rem, 14vw, 14rem);"
  aria-labelledby="seogeo-heading"
  id="seo-geo"
>
  <div class="container">

    <div class="grid grid-cols-1 md:grid-cols-[2fr_3fr] gap-16 md:gap-24">

      <!-- Left on desktop, bottom on mobile: services list + CTA -->
      <div class="reveal flex flex-col justify-end order-last md:order-first" id="seogeo-services" style="padding-bottom: 0.25rem;">

        <!-- Services label -->
        <p class="font-label text-xs tracking-widest uppercase mb-6" style="color: #8a8880;">
          Internet Marketing Services
        </p>

        <!-- Services list -->
        <ul class="stagger mb-10" aria-label="Internet marketing services offered">
          <li class="font-body text-text py-4 border-t" style="font-size: 1rem; border-color: rgba(240,235,225,0.08);">
            Search Engine Optimization (SEO)
          </li>
          <li class="font-body text-text py-4 border-t" style="font-size: 1rem; border-color: rgba(240,235,225,0.08);">
            Generative Engine Optimization (GEO)
          </li>
          <li class="font-body text-text py-4 border-t" style="font-size: 1rem; border-color: rgba(240,235,225,0.08);">
            Content Marketing &amp; Blogging
          </li>
          <li class="font-body text-text py-4 border-t" style="font-size: 1rem; border-color: rgba(240,235,225,0.08);">
            Local Lead Generation
          </li>
          <li class="py-4 border-t border-b" style="border-color: rgba(240,235,225,0.08);"></li>
        </ul>

        <!-- CTA -->
        <a
          href="#contact"
          class="inline-flex items-center self-start font-label text-xs font-semibold tracking-widest uppercase text-text bg-accent hover:bg-accent-hover px-8 py-4 transition-colors duration-200 active:scale-[0.97]"
          style="border-radius: 0;"
        >
          Get My Free Audit
        </a>

      </div>

      <!-- Right on desktop, top on mobile: narrative + 3 signs -->
      <div class="reveal order-first md:order-last" id="seogeo-copy">

        <!-- Section number -->
        <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
          02
        </p>

        <!-- H2 -->
        <h2
          id="seogeo-heading"
          class="font-display font-bold tracking-tight text-text mb-10"
          style="font-size: clamp(2rem, 4vw, 3.5rem);"
        >
          Rank on Google.<br class="hidden md:block" />
          Show Up in AI.<br class="hidden md:block" />
          Own Both.
        </h2>

        <!-- Body paragraphs — SEO anchor "Internet Marketing Service" in opening sentence -->
        <div class="space-y-6 max-w-2xl">

          <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
            If a customer in Kansas City searches for your service and you're not on the first page, you don't exist. That's the whole conversation.
          </p>

          <p class="font-body leading-relaxed text-text" style="font-size: 1.125rem;">
            <strong style="color: #f0ebe1; font-weight: 800;">Dominion</strong> runs internet marketing services built for how people search today, not ten years ago. Traditional SEO still matters. Google still ranks based on keyword authority, backlinks, and content depth. But search has changed. Customers aren't only typing into Google anymore. They're asking ChatGPT which local businesses to call. They're getting answers from Perplexity and Google AI Overviews. If you're not showing up in those results, you're invisible to a growing share of your market.
          </p>

          <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
            In Kansas City, most businesses have no strategy for AI search at all. That gap closes fast for the ones that move first.
          </p>

          <p class="font-body leading-relaxed text-text" style="font-size: 1.125rem;">
            <strong style="color: #f0ebe1; font-weight: 800;">Dominion</strong> optimizes for both channels under one roof. Traditional Google rankings and AI-generated search results, running simultaneously. This is <span style="color: #c8511a; font-weight: 500;">The Authority Stack</span> — <strong style="color: #f0ebe1; font-weight: 800;">Dominion</strong>'s combined SEO and GEO approach. Most Kansas City agencies run one or the other. We run both.
          </p>

        </div>

        <!-- 3 Signs callout -->
        <div class="mt-10 max-w-2xl" style="border-left: 2px solid #c8511a; padding-left: 1.5rem;">

          <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
            3 Signs Your Internet Marketing Isn't Working
          </p>

          <ul class="stagger space-y-4">
            <li class="flex items-start gap-4 font-body text-text-muted" style="font-size: 1.125rem;">
              <span class="font-display font-bold shrink-0" style="color: #c8511a; font-size: 0.875rem; margin-top: 0.2rem;">01</span>
              You rank for your business name but not for the services customers actually search for
            </li>
            <li class="flex items-start gap-4 font-body text-text-muted" style="font-size: 1.125rem;">
              <span class="font-display font-bold shrink-0" style="color: #c8511a; font-size: 0.875rem; margin-top: 0.2rem;">02</span>
              Your site gets traffic but the phone doesn't ring
            </li>
            <li class="flex items-start gap-4 font-body text-text-muted" style="font-size: 1.125rem;">
              <span class="font-display font-bold shrink-0" style="color: #c8511a; font-size: 0.875rem; margin-top: 0.2rem;">03</span>
              Your agency has never mentioned GEO or AI search visibility
            </li>
          </ul>

        </div>

      </div>

    </div>

  </div>
</section>

<script>
  ['seogeo-copy', 'seogeo-services'].forEach((id, i) => {
    const el = document.getElementById(id);
    if (!el) return;
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          setTimeout(() => el.classList.add('visible'), i * 120);
          observer.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    observer.observe(el);
  });
</script>
