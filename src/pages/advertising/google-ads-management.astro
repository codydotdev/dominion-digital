---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import FloatingPaths from '../../components/FloatingPaths.astro';
---

<Layout
  title="Google Ads Management Kansas City | Dominion.Digital"
  description="Google Ads management for Kansas City businesses focused on cost-per-lead. Campaign setup, conversion tracking, monthly optimization, and transparent reporting on every dollar spent."
  canonicalUrl="https://dominion.digital/advertising/google-ads-management"
>
  <Fragment slot="head">
    <script type="application/ld+json">
    [
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://dominion.digital"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Advertising",
            "item": "https://dominion.digital/advertising"
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": "Google Ads Management",
            "item": "https://dominion.digital/advertising/google-ads-management"
          }
        ]
      },
      {
        "@context": "https://schema.org",
        "@type": "Service",
        "@id": "https://dominion.digital/advertising/google-ads-management#service",
        "name": "Google Ads Management",
        "serviceType": "Google Ads Management",
        "provider": {
          "@type": "Organization",
          "@id": "https://dominion.digital/#organization",
          "name": "Dominion.Digital"
        },
        "areaServed": {
          "@type": "City",
          "name": "Kansas City",
          "addressRegion": "MO"
        },
        "url": "https://dominion.digital/advertising/google-ads-management"
      },
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "How much should I spend on Google Ads?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "It depends on your average customer value and your cost-per-lead target. Dominion.Digital works backward from what a new customer is worth to you, then sets a budget that can produce a positive return at a realistic cost-per-lead. Most Kansas City service businesses start in the $1,000 to $3,000 per month range and scale from there."
            }
          },
          {
            "@type": "Question",
            "name": "Do you manage ads on other platforms besides Google?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Google Search is the primary platform for most Kansas City service businesses because it captures active buyers. For businesses that want broader reach, Dominion.Digital can extend into display and retargeting. Social ad management is handled through the PPC strategy service."
            }
          },
          {
            "@type": "Question",
            "name": "How quickly will I start seeing leads?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Google Ads can produce leads within the first week once campaigns go live, assuming conversion tracking and landing pages are set up correctly. Dominion.Digital prioritizes getting that foundation right before launch so the early data is clean and usable."
            }
          }
        ]
      }
    ]
    </script>
  </Fragment>

  <Nav />

  <main>

    <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
    <section
      class="relative"
      style="padding-top: clamp(9rem, 18vw, 14rem); padding-bottom: clamp(5rem, 10vw, 8rem);"
      aria-label="Google Ads Management hero"
    >
      <FloatingPaths />
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(200,81,26,0.07) 0%, transparent 70%); z-index: 0;"
        aria-hidden="true"
      ></div>

      <div class="container relative" style="z-index: 1;">

        <p class="font-label text-xs tracking-widest uppercase mb-6 reveal" style="color: #8a8880;">
          <a href="/" class="hover:text-text transition-colors duration-200">Home</a>
          <span style="margin: 0 0.5rem; color: rgba(240,235,225,0.25);">/</span>
          <a href="/advertising" class="hover:text-text transition-colors duration-200">Advertising</a>
          <span style="margin: 0 0.5rem; color: rgba(240,235,225,0.25);">/</span>
          Google Ads Management
        </p>

        <h1
          class="font-display font-extrabold text-text tracking-tighter leading-none reveal"
          style="font-size: clamp(3rem, 6.5vw, 6.5rem); max-width: 18ch; margin-bottom: 2rem;"
        >
          Kansas City Google Ads Management That Turns Ad Spend Into Leads
        </h1>

        <p class="font-body text-text-muted reveal" style="font-size: 1.125rem; max-width: 52ch; margin-bottom: 2rem; line-height: 1.6;">
          Most Kansas City businesses have tried Google Ads and watched spend disappear with no leads to show for it. Bad targeting, weak copy, and no conversion tracking will do that. Dominion.Digital fixes all three.
        </p>

        <div class="flex flex-wrap items-center reveal" style="gap: 1rem;">
          <button
            type="button"
            data-open-contact
            class="btn-cta inline-flex items-center font-label font-semibold tracking-widest uppercase text-text bg-accent hover:bg-accent-hover active:scale-[0.97] transition-all duration-200"
            style="font-size: 0.7rem; padding: 0.6rem 1.25rem;"
          >
            Audit My Google Ads Account
          </button>
          <a
            href="/advertising/ppc-campaign-strategy"
            class="inline-flex items-center font-label font-semibold tracking-widest uppercase text-text hover:text-accent transition-colors duration-200"
            style="font-size: 0.7rem; padding: 0.6rem 1.25rem; border: 1px solid rgba(240,235,225,0.25); border-radius: 9999px;"
            id="hero-ghost-secondary"
          >
            See PPC Strategy
          </a>
        </div>

      </div>
    </section>


    <!-- ─── OPENING / PUNCHLINE ───────────────────────────────────────────── -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem);"
      aria-labelledby="opening-punchline"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[3fr_2fr] items-start" style="gap: clamp(3rem, 6vw, 6rem);" id="opening-block">

          <div>
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
              Advertising / Google Ads
            </p>
            <div style="max-width: 60ch;">
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem; margin-bottom: 1.5rem;">
                Most Kansas City businesses have tried Google Ads at some point. Many ran them internally, some hired an agency, and a lot of them spent thousands before deciding ads don't work. The problem was rarely the platform. Poor keyword targeting, ad copy that doesn't match what a searcher wants, and landing pages that don't convert are what kill campaigns. Fix those three things and the same budget produces entirely different results.
              </p>
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem; margin-bottom: 1.5rem;">
                Google Ads management as an advertising agency service is focused on leads at a cost that makes business sense. Every campaign Dominion.Digital manages is set up with conversion tracking from day one, structured around keywords that bring buyers, and optimized every month based on what the data shows.
              </p>
              <p class="font-body leading-relaxed text-text" style="font-size: 1.125rem;">
                The platform works. The setup and management determine whether it pays.
              </p>
            </div>
          </div>

          <div class="reveal" id="punchline-card" style="margin-top: 2rem;">
            <div style="border: 1px solid rgba(200,81,26,0.25); padding: clamp(2rem, 4vw, 3rem); position: relative; overflow: hidden;">
              <div aria-hidden="true" style="position: absolute; inset: 0; pointer-events: none; background: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(200,81,26,0.06) 0%, transparent 70%);"></div>
              <p class="font-label text-xs tracking-widest uppercase mb-6" style="color: #8a8880;">The Focus</p>
              <p
                class="font-display font-bold tracking-tight text-text"
                id="opening-punchline"
                style="font-size: clamp(1.5rem, 2.5vw, 2rem); line-height: 1.2;"
              >
                Every campaign is measured on cost-per-lead. The goal is leads at a cost that makes business sense.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- ─── WHAT'S INCLUDED ───────────────────────────────────────────────── -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem); background: #161614;"
      aria-labelledby="includes-heading"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[2fr_3fr] items-start" style="gap: clamp(3rem, 6vw, 6rem);" id="includes-block">

          <div>
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">What's Included</p>
            <h2
              id="includes-heading"
              class="font-display font-bold tracking-tight text-text"
              style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 2rem; line-height: 1.1;"
            >
              Full Campaign<br />Management.
            </h2>

            <div class="stagger" style="display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 2.5rem;" aria-label="Google Ads capabilities">
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Campaign Structure</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Keyword Research</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Conversion Tracking</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Monthly Optimization</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Cost-Per-Lead Reporting</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Landing Page Review</span>
            </div>

            <div style="border-top: 1px solid rgba(200,81,26,0.2); padding-top: 1.5rem;">
              <p class="font-label text-xs tracking-widest uppercase" style="color: #c8511a; margin-bottom: 0.75rem;">Transparent Reporting</p>
              <p class="font-body text-text-muted" style="font-size: 1rem; line-height: 1.6;">
                Every month you see spend, leads generated, cost per lead, and Quality Score. Every dollar is accounted for.
              </p>
            </div>
          </div>

          <div>
            <ul class="stagger" style="display: flex; flex-direction: column; gap: 0.75rem;" aria-label="What Google Ads management includes">

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Campaign structure and keyword research</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Search campaigns built around high-intent keywords that indicate a buyer is ready to act and call</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Ad copy and headline variants</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Multiple headline and description sets per ad group, written to match search intent and drive the specific action you need</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Conversion tracking setup</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Calls, form fills, and page events tracked from day one so every lead is attributed to its source</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Monthly bid management and optimization</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Bids, match types, negative keywords, and ad schedules adjusted each month based on what the data shows</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Landing page review and recommendations</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">The page your ads send traffic to is reviewed for conversion rate before spend begins</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Monthly reporting</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Cost per lead, ROAS, click-through rate, and Quality Score delivered every month so you know exactly what the budget produced</p>
                </div>
              </li>

            </ul>
          </div>

        </div>
      </div>
    </section>


    <!-- ─── WHY IT MATTERS ────────────────────────────────────────────────── -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem);"
      aria-labelledby="matters-heading"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[2fr_3fr] items-start" style="gap: clamp(3rem, 6vw, 6rem);" id="matters-block">

          <div>
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">The Metric</p>
            <p
              class="font-display font-bold tracking-tighter text-accent"
              style="font-size: clamp(3rem, 6vw, 5.5rem); line-height: 0.9; margin-bottom: 1rem;"
            >
              Per<br />Lead.
            </p>
            <p class="font-body text-text-muted" style="font-size: 1rem; max-width: 28ch; line-height: 1.5;">
              Cost-per-lead is the number that determines whether a Google Ads campaign is working. Every optimization decision ties back to it.
            </p>
          </div>

          <div>
            <h2
              id="matters-heading"
              class="font-display font-bold tracking-tight text-text"
              style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 2rem; line-height: 1.1;"
            >
              Quality Score Is the Multiplier. Better Setup Means Lower Cost Per Click.
            </h2>
            <div style="max-width: 58ch;">
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem; margin-bottom: 1.5rem;">
                A Google Ads campaign managed for click volume produces traffic. A campaign managed for cost-per-lead produces business. Those are different goals that require different setups.
              </p>
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem; margin-bottom: 1.5rem;">
                Quality Score is Google's rating of how relevant your keywords, ads, and landing pages are to each other. A high Quality Score lowers your cost per click. Lower cost per click means more leads for the same budget. A campaign built around buyer intent and matched to a converting page improves Quality Score over time.
              </p>
              <p class="font-body leading-relaxed text-text" style="font-size: 1.125rem; font-weight: 500;">
                Every point of Quality Score improvement lowers what you pay per click. The right setup compounds in your favor.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- ─── HOW WE APPROACH IT ────────────────────────────────────────────── -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem); background: #161614;"
      aria-labelledby="process-heading"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[2fr_3fr] items-start" style="gap: clamp(3rem, 6vw, 6rem);" id="process-block">

          <div class="md:sticky" style="top: 6rem;">
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">The Process</p>
            <h2
              id="process-heading"
              class="font-display font-bold tracking-tight text-text"
              style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 1.5rem; line-height: 1.1;"
            >
              Audit First. Build the Structure. Optimize Every Month.
            </h2>
            <p class="font-body text-text-muted" style="font-size: 1rem; max-width: 32ch; line-height: 1.6;">
              Every engagement starts with an account audit or competitive research before a dollar gets spent. The structure determines the results.
            </p>
          </div>

          <div>
            <ul class="stagger" aria-label="Google Ads management process steps">

              <li class="py-6" style="border-top: 1px solid rgba(240,235,225,0.08);">
                <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
                  <span class="font-label font-bold" style="color: #c8511a; font-size: 0.75rem; margin-top: 0.2rem; flex-shrink: 0;">01</span>
                  <div>
                    <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem;">Account audit or competitive research</p>
                    <p class="font-body text-text-muted" style="font-size: 0.95rem; line-height: 1.6;">Existing accounts are audited for wasted spend, structural problems, and conversion gaps. New accounts get keyword and competitor research before anything is built.</p>
                  </div>
                </div>
              </li>

              <li class="py-6" style="border-top: 1px solid rgba(240,235,225,0.08);">
                <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
                  <span class="font-label font-bold" style="color: #c8511a; font-size: 0.75rem; margin-top: 0.2rem; flex-shrink: 0;">02</span>
                  <div>
                    <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem;">Campaign structure and ad copy</p>
                    <p class="font-body text-text-muted" style="font-size: 0.95rem; line-height: 1.6;">Campaigns are organized around buyer intent. Ad groups, match types, and copy are built to match specific search queries and drive the action you need.</p>
                  </div>
                </div>
              </li>

              <li class="py-6" style="border-top: 1px solid rgba(240,235,225,0.08);">
                <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
                  <span class="font-label font-bold" style="color: #c8511a; font-size: 0.75rem; margin-top: 0.2rem; flex-shrink: 0;">03</span>
                  <div>
                    <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem;">Conversion tracking and landing page review</p>
                    <p class="font-body text-text-muted" style="font-size: 0.95rem; line-height: 1.6;">Call and form tracking goes in before launch. The landing page is reviewed for conversion rate so the traffic your ads send has somewhere to go that converts.</p>
                  </div>
                </div>
              </li>

              <li class="py-6" style="border-top: 1px solid rgba(240,235,225,0.08);">
                <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
                  <span class="font-label font-bold" style="color: #c8511a; font-size: 0.75rem; margin-top: 0.2rem; flex-shrink: 0;">04</span>
                  <div>
                    <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem;">Campaign launch</p>
                    <p class="font-body text-text-muted" style="font-size: 0.95rem; line-height: 1.6;">Campaigns go live once structure, tracking, and landing pages are confirmed. Most Kansas City businesses start seeing leads within the first week.</p>
                  </div>
                </div>
              </li>

              <li class="py-6" style="border-top: 1px solid rgba(240,235,225,0.08); border-bottom: 1px solid rgba(240,235,225,0.08);">
                <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
                  <span class="font-label font-bold" style="color: #c8511a; font-size: 0.75rem; margin-top: 0.2rem; flex-shrink: 0;">05</span>
                  <div>
