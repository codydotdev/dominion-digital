---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import FloatingPaths from '../../components/FloatingPaths.astro';
---

<Layout
  title="Custom Web Development Kansas City | Dominion.Digital"
  description="Custom web development for Kansas City businesses that have outgrown templates. Built from scratch, to spec, with integrations and automation baked in from day one."
  canonicalUrl="https://dominion.digital/web-design/custom-web-development"
>
  <Fragment slot="head">
    <script type="application/ld+json">
    [
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://dominion.digital"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Web Design",
            "item": "https://dominion.digital/web-design"
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": "Custom Web Development",
            "item": "https://dominion.digital/web-design/custom-web-development"
          }
        ]
      },
      {
        "@context": "https://schema.org",
        "@type": "Service",
        "@id": "https://dominion.digital/web-design/custom-web-development#service",
        "name": "Custom Web Development",
        "serviceType": "Custom Web Development",
        "provider": {
          "@type": "Organization",
          "@id": "https://dominion.digital/#organization",
          "name": "Dominion.Digital"
        },
        "areaServed": {
          "@type": "City",
          "name": "Kansas City",
          "addressRegion": "MO"
        },
        "url": "https://dominion.digital/web-design/custom-web-development"
      },
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "How much does custom web development cost in Kansas City?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Custom development ranges based on scope. A site with one or two integrations and custom pages runs differently than a full web application with a client portal and automated workflows. Dominion.Digital scopes every project before quoting so you know exactly what you're getting and what it costs before anything starts."
            }
          },
          {
            "@type": "Question",
            "name": "How long does a custom build take?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Most custom projects run 6 to 12 weeks from scoping to launch. More complex builds with multiple integrations take longer. Dominion.Digital sets a clear timeline during scoping and holds to it."
            }
          },
          {
            "@type": "Question",
            "name": "Can you integrate my existing CRM, booking system, or other tools?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. Integration work is a standard part of most custom builds. If your tool has an API, it can be connected. Dominion.Digital handles the setup, testing, and documentation so your team doesn't have to figure it out after launch."
            }
          }
        ]
      }
    ]
    </script>
  </Fragment>

  <Nav />

  <main>

    <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
    <section
      class="relative"
      style="padding-top: clamp(9rem, 18vw, 14rem); padding-bottom: clamp(5rem, 10vw, 8rem);"
      aria-label="Custom Web Development hero"
    >
      <FloatingPaths />
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(200,81,26,0.07) 0%, transparent 70%); z-index: 0;"
        aria-hidden="true"
      ></div>

      <div class="container relative" style="z-index: 1;">

        <!-- Breadcrumb -->
        <p class="font-label text-xs tracking-widest uppercase mb-6 reveal" style="color: #8a8880;">
          <a href="/" class="hover:text-text transition-colors duration-200">Home</a>
          <span style="margin: 0 0.5rem; color: rgba(240,235,225,0.25);">/</span>
          <a href="/web-design" class="hover:text-text transition-colors duration-200">Web Design</a>
          <span style="margin: 0 0.5rem; color: rgba(240,235,225,0.25);">/</span>
          Custom Web Development
        </p>

        <h1
          class="font-display font-extrabold text-text tracking-tighter leading-none reveal"
          style="font-size: clamp(3rem, 6.5vw, 6.5rem); max-width: 18ch; margin-bottom: 2rem;"
        >
          Custom Web Development for Kansas City Businesses That Outgrew Templates
        </h1>

        <p class="font-body text-text-muted reveal" style="font-size: 1.125rem; max-width: 52ch; margin-bottom: 2rem; line-height: 1.6;">
          Your business runs a specific way. Your website should too. Most websites are just templates built for someone else's business first. You want your website built from scratch, to spec, no compromises.
        </p>

        <div class="flex flex-wrap items-center gap-4 reveal">
          <button
            type="button"
            data-open-contact
            class="btn-cta inline-flex items-center font-label font-semibold tracking-widest uppercase text-text bg-accent hover:bg-accent-hover active:scale-[0.97] transition-all duration-200"
            style="font-size: 0.7rem; padding: 0.6rem 1.25rem;"
          >
            Scope My Custom Build
          </button>
          <a
            href="/web-design/high-conversion-web-design"
            class="inline-flex items-center font-label font-semibold tracking-widest uppercase text-text hover:text-accent transition-colors duration-200"
            style="font-size: 0.7rem; padding: 0.6rem 1.25rem; border: 1px solid rgba(240,235,225,0.25); border-radius: 9999px;"
            id="hero-ghost-secondary"
          >
            See High-Conversion Design
          </a>
        </div>

      </div>
    </section>


    <!-- ─── OPENING / PUNCHLINE ───────────────────────────────────────────── -->
    <!-- Pattern A: 3fr/2fr split — narrative left, punchline card right -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem);"
      aria-labelledby="opening-punchline"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[3fr_2fr] items-start gap-16 md:gap-24" id="opening-block">

          <!-- Left: narrative -->
          <div>
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
              Web Design / Custom Development
            </p>
            <div class="space-y-6" style="max-width: 60ch;">
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
                At some point, a template stops being a solution and starts being a ceiling. You need a form that connects to your CRM. A client portal. A booking system that matches how your business actually runs. An integration that Squarespace doesn't support and WordPress plugins handle badly.
              </p>
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
                Custom web development is what Kansas City businesses turn to when they've outgrown out-of-the-box options and need something built specifically for how they operate. <strong style="font-weight: 800; color: #f0ebe1;">Dominion</strong><span style="color: #c8511a;">.</span><span style="font-weight: 400; color: #f0ebe1;">Digital</span> builds sites and web applications from scratch, to your exact requirements, with no workarounds.
              </p>
              <p class="font-body leading-relaxed text-text" style="font-size: 1.125rem;">
                Every custom build starts with what your business actually needs to happen, then gets built backwards from that outcome.
              </p>
            </div>
          </div>

          <!-- Right: punchline card -->
          <div class="reveal" id="punchline-card" style="margin-top: 2rem;">
            <div style="border: 1px solid rgba(200,81,26,0.25); padding: clamp(2rem, 4vw, 3rem); position: relative; overflow: hidden;">
              <div aria-hidden="true" style="position: absolute; inset: 0; pointer-events: none; background: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(200,81,26,0.06) 0%, transparent 70%);"></div>
              <p class="font-label text-xs tracking-widest uppercase mb-6" style="color: #8a8880;">
                The Principle
              </p>
              <p
                class="font-display font-bold tracking-tight text-text"
                id="opening-punchline"
                style="font-size: clamp(1.5rem, 2.5vw, 2rem); line-height: 1.2;"
              >
                When the template stops working, the custom build starts.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- ─── WHAT'S INCLUDED ───────────────────────────────────────────────── -->
    <!-- Pattern A flipped: 2fr/3fr — pills + guarantee left, bento list right, surface bg -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem); background: #161614;"
      aria-labelledby="includes-heading"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[2fr_3fr] items-start gap-16 md:gap-24" id="includes-block">

          <!-- Left: label + pills + guarantee anchor -->
          <div>
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
              What's Included
            </p>
            <h2
              id="includes-heading"
              class="font-display font-bold tracking-tight text-text"
              style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 2rem; line-height: 1.1;"
            >
              Built to Spec.<br />Every Time.
            </h2>

            <!-- Pill cluster: Rapid Fire Benefits -->
            <div class="stagger" style="display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 2.5rem;" aria-label="Custom development capabilities">
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Custom Functionality</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">CRM & API Integrations</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Scalable Architecture</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Automation-Ready</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Performance Built In</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">SEO-Ready From Day One</span>
            </div>

            <!-- Guarantee anchor -->
            <div style="border-top: 1px solid rgba(200,81,26,0.2); padding-top: 1.5rem;">
              <p class="font-label text-xs tracking-widest uppercase" style="color: #c8511a; margin-bottom: 0.75rem;">
                The Website Guarantee
              </p>
              <p class="font-body text-text-muted" style="font-size: 1rem; line-height: 1.6;">
                If you're not satisfied at any point during the build, you get every dollar back. No questions. <strong style="font-weight: 800; color: #f0ebe1;">Dominion</strong><span style="color: #c8511a;">.</span><span style="font-weight: 400; color: #f0ebe1;">Digital</span> doesn't launch until you'd be proud to send that URL to your best client.
              </p>
            </div>

          </div>

          <!-- Right: Bento Checkmarks — Scope / Inclusion List -->
          <div>
            <ul class="stagger space-y-3" aria-label="What custom web development includes">

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Custom design and development</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Built from scratch to your spec, not adapted from a theme or template</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Third-party integrations</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">CRM connections, payment processors, booking systems, and APIs — connected and tested</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Scalable architecture</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Built to grow with your business, not rebuilt when you do</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Automation-ready infrastructure</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">AI automation workflows can be built into the same project from the start, not bolted on later</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Performance optimization</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Fast load times and clean code baked in at the foundation, not patched in after launch</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">SEO-ready structure</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Proper heading hierarchy and technical signals deployed from the first build</p>
                </div>
              </li>

            </ul>
          </div>

        </div>
      </div>
    </section>


    <!-- ─── WHY IT MATTERS ────────────────────────────────────────────────── -->
    <!-- Pattern A: copy right, punchline callout left -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem);"
      aria-labelledby="matters-heading"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[2fr_3fr] items-start gap-16 md:gap-24" id="matters-block">

          <!-- Left: punchline callout -->
          <div>
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
              The Reality
            </p>
            <p
              class="font-display font-bold tracking-tighter text-accent"
              style="font-size: clamp(2.5rem, 5vw, 4.5rem); line-height: 0.95; margin-bottom: 1rem;"
            >
              The right infrastructure compounds.
            </p>
            <p class="font-body text-text-muted" style="font-size: 1rem; max-width: 28ch; line-height: 1.5;">
              The wrong one costs you every time something breaks.
            </p>
          </div>

          <!-- Right: narrative -->
          <div>
            <h2
              id="matters-heading"
              class="font-display font-bold tracking-tight text-text"
              style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 2rem; line-height: 1.1;"
            >
              Templates Have a Ceiling. Custom Builds Don't.
            </h2>
            <div class="space-y-6" style="max-width: 58ch;">
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
                A template site has two problems once your business grows. First, it limits what you can do. When your process requires a custom workflow and the platform doesn't support it, you end up bending the business to fit the tool. Second, template sites carry technical debt. Every plugin, every workaround, every patch slows things down and creates failure points.
              </p>
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
                A custom build gives you a site that works the way your business works. Integrations that connect your tools without duct tape. Performance that doesn't degrade as you add pages. A foundation built for where you're going, not where you started.
              </p>
              <p class="font-body leading-relaxed text-text" style="font-size: 1.125rem; font-weight: 500;">
                The right infrastructure compounds. The wrong one costs you every time something breaks.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- ─── HOW WE APPROACH IT ────────────────────────────────────────────── -->
    <!-- Pattern E: Sticky sidecar — label + heading left, scrolling steps right, surface bg -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem); background: #161614;"
      aria-labelledby="process-heading"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[2fr_3fr] items-start gap-16 md:gap-24" id="process-block">

          <!-- Left: sticky label + heading -->
          <div class="md:sticky" style="top: 6rem;">
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
              The Process
            </p>
            <h2
              id="process-heading"
              class="font-display font-bold tracking-tight text-text"
              style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 1.5rem; line-height: 1.1;"
            >
              Scoped First. Built Right.
            </h2>
            <p class="font-body text-text-muted" style="font-size: 1rem; max-width: 32ch; line-height: 1.6;">
              Every <strong style="font-weight: 800; color: #f0ebe1;">Dominion</strong><span style="color: #c8511a;">.</span><span style="font-weight: 400; color: #f0ebe1;">Digital</span> custom project starts with a scoping session. What does your site need to do? What systems does it need to connect to? That defines everything that comes after it.
            </p>
          </div>

          <!-- Right: process steps -->
          <div>
            <ul class="stagger" aria-label="Custom web development process">

              <li class="py-6" style="border-top: 1px solid rgba(240,235,225,0.08);">
                <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
                  <span class="font-label font-bold" style="color: #c8511a; font-size: 0.75rem; margin-top: 0.2rem; flex-shrink: 0;">01</span>
                  <div>
                    <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem;">Scoping session</p>
                    <p class="font-body text-text-muted" style="font-size: 0.95rem; line-height: 1.6;">We define requirements before any work begins. What does your site need to do? What systems does it need to talk to? What does the full user journey look like?</p>
                  </div>
                </div>
              </li>

              <li class="py-6" style="border-top: 1px solid rgba(240,235,225,0.08);">
                <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
                  <span class="font-label font-bold" style="color: #c8511a; font-size: 0.75rem; margin-top: 0.2rem; flex-shrink: 0;">02</span>
                  <div>
                    <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem;">Technical architecture review</p>
                    <p class="font-body text-text-muted" style="font-size: 0.95rem; line-height: 1.6;"><strong style="font-weight: 800; color: #f0ebe1;">Dominion</strong><span style="color: #c8511a;">.</span><span style="font-weight: 400; color: #f0ebe1;">Digital</span> maps the full technical architecture before writing a line of code. Design, development, and integration logic are all planned before anything is built.</p>
                  </div>
                </div>
              </li>

              <li class="py-6" style="border-top: 1px solid rgba(240,235,225,0.08);">
                <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
                  <span class="font-label font-bold" style="color: #c8511a; font-size: 0.75rem; margin-top: 0.2rem; flex-shrink: 0;">03</span>
                  <div>
                    <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem;">Integration setup and testing</p>
                    <p class="font-body text-text-muted" style="font-size: 0.95rem; line-height: 1.6;">Every third-party connection is built and tested end-to-end before launch. No untested integrations go live.</p>
                  </div>
                </div>
              </li>

