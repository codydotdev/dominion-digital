<style>
  /* FAQ accordion — identical to high-conversion web design page */
  .faq-body {
    overflow: hidden;
    max-height: 0;
    transition: max-height 480ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .faq-body.is-open {
    max-height: 600px;
  }
  .faq-body-inner {
    padding-bottom: 1.5rem;
  }

  @keyframes faq-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  .faq-icon {
    animation: faq-spin 4s linear infinite;
  }
  .faq-icon.is-open {
    animation: none;
    transform: rotate(180deg);
  }
</style>


<script>
  // ─── Scroll reveal: fire once per element ─────────────────────────────────
  const revealIds = [
    'opening-block',
    'punchline-card',
    'includes-block',
    'matters-block',
    'process-block',
    'faq-content',
    'related-block',
    'cta-block',
  ];

  revealIds.forEach((id, i) => {
    const el = document.getElementById(id);
    if (!el) return;
    if (!el.classList.contains('reveal')) return;
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          setTimeout(() => el.classList.add('visible'), i * 60);
          observer.disconnect();
        }
      },
      { threshold: 0.08 }
    );
    observer.observe(el);
  });

  // Catch all remaining .reveal elements not covered above
  document.querySelectorAll('.reveal').forEach((el) => {
    if (el.classList.contains('visible')) return;
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          el.classList.add('visible');
          observer.disconnect();
        }
      },
      { threshold: 0.08 }
    );
    observer.observe(el);
  });

  // ─── FAQ accordion ─────────────────────────────────────────────────────────
  document.querySelectorAll('.faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const item   = trigger.closest('.faq-item')!;
      const body   = item.querySelector('.faq-body') as HTMLElement;
      const icon   = trigger.querySelector('.faq-icon') as HTMLElement;
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      if (isOpen) {
        body.classList.remove('is-open');
        icon.classList.remove('is-open');
        trigger.setAttribute('aria-expanded', 'false');
      } else {
        body.classList.add('is-open');
        icon.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // ─── Ghost CTA hover: border → accent ─────────────────────────────────────
  ['hero-ghost-secondary', 'cta-ghost'].forEach(id => {
    const el = document.getElementById(id) as HTMLAnchorElement | null;
    if (!el) return;
    el.addEventListener('mouseenter', () => { el.style.borderColor = '#c8511a'; });
    el.addEventListener('mouseleave', () => { el.style.borderColor = 'rgba(240,235,225,0.25)'; });
  });
</script>
