<style>
  /* Warning icon pulse */
  @keyframes warn-pulse {
    0%, 100% { filter: drop-shadow(0 0 4px rgba(200,81,26,0.6)); opacity: 1; }
    50%       { filter: drop-shadow(0 0 12px rgba(200,81,26,0.95)); opacity: 0.8; }
  }
  .warn-icon {
    animation: warn-pulse 2.4s ease-in-out infinite;
  }

  /* FAQ slide animation */
  .faq-body {
    overflow: hidden;
    max-height: 0;
    transition: max-height 480ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .faq-body.is-open {
    max-height: 600px;
  }
  .faq-body-inner {
    padding-bottom: 1.5rem;
  }

  /* Triangle: spin when closed, freeze rotated when open */
  @keyframes faq-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
  }
  .faq-icon {
    animation: faq-spin 4s linear infinite;
  }
  .faq-icon.is-open {
    animation: none;
    transform: rotate(180deg);
  }
</style>

<script>
  // Scroll reveal: all .reveal elements on this page
  document.querySelectorAll<HTMLElement>('.reveal').forEach((el, i) => {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          setTimeout(() => el.classList.add('visible'), i < 4 ? i * 80 : 0);
          observer.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    observer.observe(el);
  });

  // Accordion with slide transition
  document.querySelectorAll('.faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const item   = trigger.closest('.faq-item')!;
      const body   = item.querySelector('.faq-body') as HTMLElement;
      const icon   = trigger.querySelector('.faq-icon') as HTMLElement;
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';

      if (isOpen) {
        body.classList.remove('is-open');
        icon.classList.remove('is-open');
        trigger.setAttribute('aria-expanded', 'false');
      } else {
        body.classList.add('is-open');
        icon.classList.add('is-open');
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
