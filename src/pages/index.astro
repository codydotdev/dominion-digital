---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Intro from '../components/Intro.astro';
import Signs from '../components/Signs.astro';
import WebDesign from '../components/WebDesign.astro';
import SeoGeo from '../components/SeoGeo.astro';
import Advertising from '../components/Advertising.astro';
import Automation from '../components/Automation.astro';
import ServiceAreas from '../components/ServiceAreas.astro';
import Guarantee from '../components/Guarantee.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="dominion.digital | Kansas City Digital Marketing Agency"
  description="dominion.digital is a Kansas City digital marketing agency that ties everything to pipeline. Web design, SEO, GEO, paid ads, and automation. Results or you don't pay."
>
  <Fragment slot="head">
    <script type="application/ld+json">
    [
      {
        "@context": "https://schema.org",
        "@type": ["Organization", "LocalBusiness"],
        "@id": "https://dominion.digital/#organization",
        "name": "Dominion.Digital",
        "url": "https://dominion.digital",
        "logo": "https://dominion.digital/images/Dominion Digital Logo White.png",
        "description": "Kansas City digital marketing agency specializing in web design, SEO, GEO, paid advertising, and AI automation. Results or you don't pay.",
        "address": {
          "@type": "PostalAddress",
          "addressLocality": "Kansas City",
          "addressRegion": "MO",
          "addressCountry": "US"
        },
        "areaServed": [
          "Kansas City, MO",
          "Overland Park, KS",
          "Lenexa, KS",
          "Olathe, KS",
          "Shawnee, KS",
          "Lee's Summit, MO",
          "Independence, MO",
          "Blue Springs, MO",
          "Raytown, MO",
          "Gladstone, MO",
          "Liberty, MO",
          "Belton, MO",
          "Raymore, MO"
        ],
        "serviceType": [
          "Web Design",
          "Internet Marketing",
          "Search Engine Optimization",
          "Generative Engine Optimization",
          "Digital Advertising",
          "AI Automation"
        ],
        "sameAs": []
      },
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "@id": "https://dominion.digital/#website",
        "url": "https://dominion.digital",
        "name": "Dominion.Digital",
        "description": "Kansas City digital marketing agency — web design, SEO, GEO, ads, and automation.",
        "publisher": { "@id": "https://dominion.digital/#organization" }
      },
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "How much does digital marketing cost in Kansas City?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dominion.Digital has three tiers. The entry option is a professional landing page for free, plus $200 per month for hosting and management. The Authority Accelerator, which includes a full 5–7 page site, local SEO, and Google Business Profile management, is $6,000 setup and $400 per month. Total Online Omnipresence, which covers a 30–40 page site, SEO, GEO, social media, Google Ads, and automation, is $10,000 setup and $1,500 per month. Every paid tier includes an unconditional site guarantee and a 90-day results guarantee."
            }
          },
          {
            "@type": "Question",
            "name": "What is GEO and why does it matter for Kansas City businesses?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "GEO stands for Generative Engine Optimization. It's the practice of optimizing your content to get cited by AI tools like ChatGPT, Perplexity, and Google AI Overviews. Traditional SEO gets you into Google's search results. GEO gets you into the AI-generated answers your customers are increasingly using to make decisions. In Kansas City, most businesses have no GEO strategy at all. That gap closes fast for the ones who move first."
            }
          },
          {
            "@type": "Question",
            "name": "How long does it take to see results from digital marketing in Kansas City?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Web design results are visible at launch. Paid advertising campaigns typically produce leads within the first 30 days when set up correctly. SEO and GEO results appear within 60–90 days in most Kansas City markets, depending on your competition level. Dominion.Digital's 90-day results guarantee is built around that timeline."
            }
          },
          {
            "@type": "Question",
            "name": "Does Dominion.Digital work with businesses outside Kansas City?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Yes. Most clients are in the Kansas City metro, but Dominion.Digital works with national clients on web design, SEO, and automation. The process is the same regardless of location."
            }
          }
        ]
      }
    ]
    </script>
  </Fragment>
  <Nav />
  <main>
    <Hero />
    <Signs />
    <WebDesign />
    <SeoGeo />
    <Advertising />
    <Automation />
    <Guarantee />
    <Intro />
    <ServiceAreas />
    <FAQ />
  </main>
  <Footer />
</Layout>
