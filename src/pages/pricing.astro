<style>
  /* Animated border shine on featured card */
  .card-shine-wrapper {
    position: relative;
    border-radius: 20px;
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .pricing-grid {
      grid-template-columns: 1fr 1.2fr 1fr;
    }
  }
</style>

<script>
  // Match left card height to right card (right card is naturally taller)
  function matchSideHeights() {
    const left  = document.querySelector<HTMLElement>('.pricing-card-left');
    const right = document.querySelector<HTMLElement>('.pricing-card-right');
    if (!left || !right) return;
    // Only apply on desktop where cards are side by side
    if (window.innerWidth >= 1024) {
      left.style.minHeight = '';
      left.style.minHeight = right.offsetHeight + 'px';
    } else {
      left.style.minHeight = '';
    }
  }

  matchSideHeights();
  window.addEventListener('resize', matchSideHeights);

  // Border shine — SVG dash travels at uniform linear speed around the rect
  const shineWrapper = document.querySelector<HTMLElement>('.card-shine-wrapper');
  if (shineWrapper) {
    const svg   = shineWrapper.querySelector<SVGSVGElement>('.card-shine-svg')!;
    const base  = shineWrapper.querySelector<SVGRectElement>('.shine-base')!;
    const spot  = shineWrapper.querySelector<SVGRectElement>('.shine-spot')!;
    let anim: Animation | null = null;

    function setup() {
      const w = shineWrapper.offsetWidth;
      const h = shineWrapper.offsetHeight;
      svg.setAttribute('viewBox', `0 0 ${w} ${h}`);
      const o = 1.25; // half of spot stroke-width
      [base, spot].forEach(el => {
        el.setAttribute('x',      String(o));
        el.setAttribute('y',      String(o));
        el.setAttribute('width',  String(w - o * 2));
        el.setAttribute('height', String(h - o * 2));
      });
      const perimeter = spot.getTotalLength();
      const spotLen   = 80;
      spot.style.strokeDasharray = `${spotLen} ${perimeter - spotLen}`;
      if (anim) anim.cancel();
      anim = spot.animate(
        [{ strokeDashoffset: '0' }, { strokeDashoffset: String(-perimeter) }],
        { duration: (perimeter / 160) * 1000, iterations: Infinity, easing: 'linear' }
      );
    }

    setup();
    window.addEventListener('resize', setup);
  }

  document.querySelectorAll<HTMLElement>('.reveal').forEach((el, i) => {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          setTimeout(() => el.classList.add('visible'), i < 4 ? i * 80 : 0);
          observer.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    observer.observe(el);
  });
</script>
