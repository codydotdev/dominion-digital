<style>
  /* Border beam on featured card */
  .card-shine-wrapper {
    position: relative;
    border-radius: 20px;
    border: 1px solid rgba(200,81,26,0.4);
  }

  .border-beam {
    position: absolute;
    inset: 0;
    border-radius: 20px;
    border: 1px solid transparent;
    -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: destination-out;
    mask-composite: exclude;
    pointer-events: none;
    z-index: 3;
  }

  .border-beam-light {
    position: absolute;
    top: 0;
    left: 0;
    width: 200px;
    aspect-ratio: 1 / 1;
    background: radial-gradient(ellipse at center, rgba(255, 190, 80, 0.9), transparent 65%);
    offset-path: var(--beam-path);
    animation: border-beam-orbit 10.4s linear infinite;
  }

  @keyframes border-beam-orbit {
    from { offset-distance: 0%; }
    to   { offset-distance: 100%; }
  }

  @keyframes pricing-guarantee-bloom-pulse {
    0%, 100% { opacity: 0.6; transform: scale(1); }
    50%       { opacity: 1;   transform: scale(1.18); }
  }
  .pricing-guarantee-bloom {
    animation: pricing-guarantee-bloom-pulse 10s ease-in-out infinite;
  }

  .pricing-guarantee-card {
    border-radius: 1rem;
    background: rgba(22, 22, 20, 0.55);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(240, 235, 225, 0.1);
    transition: transform 700ms ease, box-shadow 700ms ease;
  }
  .pricing-guarantee-card:hover,
  .pricing-guarantee-card:active {
    transform: scale(1.025);
    box-shadow: 0 0 0 1px rgba(200, 81, 26, 0.25), 0 0 30px rgba(200, 81, 26, 0.2), 0 0 60px rgba(200, 81, 26, 0.1);
  }

  .pricing-card-side,
  .pricing-card-center {
    transition: transform 400ms ease;
  }
  .pricing-card-side:hover,
  .pricing-card-side:active,
  .pricing-card-center:hover,
  .pricing-card-center:active {
    transform: scale(1.025);
  }

  .pricing-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .pricing-grid {
      grid-template-columns: 1fr 1.2fr 1fr;
    }
  }
</style>

<script>
  // Match left card height to right card (right card is naturally taller)
  function matchSideHeights() {
    const left  = document.querySelector<HTMLElement>('.pricing-card-left');
    const right = document.querySelector<HTMLElement>('.pricing-card-right');
    if (!left || !right) return;
    // Only apply on desktop where cards are side by side
    if (window.innerWidth >= 1024) {
      left.style.minHeight = '';
      left.style.minHeight = right.offsetHeight + 'px';
    } else {
      left.style.minHeight = '';
    }
  }

  matchSideHeights();
  window.addEventListener('resize', matchSideHeights);

  // Border beam — radial gradient orbits the card border
  const beamWrapper = document.querySelector<HTMLElement>('.card-shine-wrapper');
  if (beamWrapper) {
    const light = beamWrapper.querySelector<HTMLElement>('.border-beam-light')!;

    function updateBeamPath() {
      const w = beamWrapper.offsetWidth;
      const h = beamWrapper.offsetHeight;
      light.style.setProperty('--beam-path', `path("M 0 0 H ${w} V ${h} H 0 V 0")`);
    }

    updateBeamPath();
    window.addEventListener('resize', updateBeamPath);
  }

  document.querySelectorAll<HTMLElement>('.reveal').forEach((el, i) => {
    const observer = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          setTimeout(() => el.classList.add('visible'), i < 4 ? i * 80 : 0);
          observer.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    observer.observe(el);
  });
</script>
