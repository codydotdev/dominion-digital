<style>
  @keyframes faq-spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(180deg); }
  }
  .faq-item.is-open .faq-icon {
    animation: faq-spin 0.3s ease forwards;
  }
  .faq-item:not(.is-open) .faq-icon {
    animation: faq-spin 0.3s ease reverse forwards;
  }
</style>

<script>
  // FAQ accordion
  document.querySelectorAll('.faq-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const item = btn.closest('.faq-item') as HTMLElement;
      const answer = item.querySelector('.faq-answer') as HTMLElement;
      const isOpen = item.classList.contains('is-open');

      if (isOpen) {
        item.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
        answer.style.maxHeight = '0';
      } else {
        item.classList.add('is-open');
        btn.setAttribute('aria-expanded', 'true');
        answer.style.maxHeight = answer.scrollHeight + 'px';
      }
    });
  });

  // Ghost CTA hover border
  const ghostBtn = document.getElementById('hero-ghost-secondary');
  if (ghostBtn) {
    ghostBtn.addEventListener('mouseenter', () => { ghostBtn.style.borderColor = '#c8511a'; });
    ghostBtn.addEventListener('mouseleave', () => { ghostBtn.style.borderColor = 'rgba(240,235,225,0.25)'; });
  }

  // Scroll reveal
  const revealIds = ['opening-block', 'punchline-card', 'includes-block', 'matters-block', 'process-block'];
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        (e.target as HTMLElement).style.opacity = '1';
        (e.target as HTMLElement).style.transform = 'translateY(0)';
        observer.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });

  revealIds.forEach(id => {
    const el = document.getElementById(id);
    if (el) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(2rem)';
      el.style.transition = 'opacity 0.7s ease, transform 0.7s ease';
      observer.observe(el);
    }
  });

  document.querySelectorAll('.reveal').forEach(el => {
    const htmlEl = el as HTMLElement;
    if (!revealIds.includes(htmlEl.id)) {
      htmlEl.style.opacity = '0';
      htmlEl.style.transform = 'translateY(1.5rem)';
      htmlEl.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      observer.observe(htmlEl);
    }
  });
</script>
