---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import FloatingPaths from '../../components/FloatingPaths.astro';
---

<Layout
  title="AI Automation Systems Kansas City | Dominion.Digital"
  description="Custom AI automation systems for Kansas City businesses. Lead follow-up, appointment booking, CRM integration, and reporting pipelines that run 24/7 without adding to payroll."
  canonicalUrl="https://dominion.digital/ai-automation/ai-automation-systems"
>
  <Fragment slot="head">
    <script type="application/ld+json">
    [
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://dominion.digital"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "AI Automation",
            "item": "https://dominion.digital/ai-automation"
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": "AI Automation Systems",
            "item": "https://dominion.digital/ai-automation/ai-automation-systems"
          }
        ]
      },
      {
        "@context": "https://schema.org",
        "@type": "Service",
        "@id": "https://dominion.digital/ai-automation/ai-automation-systems#service",
        "name": "AI Automation Systems",
        "serviceType": "AI Automation Systems",
        "provider": {
          "@type": "Organization",
          "@id": "https://dominion.digital/#organization",
          "name": "Dominion.Digital"
        },
        "areaServed": {
          "@type": "City",
          "name": "Kansas City",
          "addressRegion": "MO"
        },
        "url": "https://dominion.digital/ai-automation/ai-automation-systems"
      },
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What kinds of tasks can actually be automated?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Lead follow-up, appointment booking, CRM updates, review request sequences, internal notifications, reporting, and content distribution are the most common starting points. If your team does a task on repeat that follows a consistent pattern, there's a good chance it can be automated. Dominion.Digital starts with a workflow audit to find the highest-value targets first."
            }
          },
          {
            "@type": "Question",
            "name": "Do I need to replace my existing tools?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "No. Dominion.Digital builds around what you already use. Most automations connect via API or native integrations with tools like HubSpot, Salesforce, GoHighLevel, Google Workspace, and others. You keep your stack and we build the logic that connects it."
            }
          },
          {
            "@type": "Question",
            "name": "How long does it take to set up AI automation?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Most automation projects are live within 2 to 4 weeks. More complex builds with multiple workflows and custom integrations take longer. Dominion.Digital scopes every project before starting so you have a clear timeline before anything begins."
            }
          }
        ]
      }
    ]
    </script>
  </Fragment>

  <Nav />

  <main>

    <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
    <section
      class="relative"
      style="padding-top: clamp(9rem, 18vw, 14rem); padding-bottom: clamp(5rem, 10vw, 8rem);"
      aria-label="AI Automation Systems hero"
    >
      <FloatingPaths />
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(200,81,26,0.07) 0%, transparent 70%); z-index: 0;"
        aria-hidden="true"
      ></div>

      <div class="container relative" style="z-index: 1;">

        <!-- Breadcrumb -->
        <p class="font-label text-xs tracking-widest uppercase mb-6 reveal" style="color: #8a8880;">
          <a href="/" class="hover:text-text transition-colors duration-200">Home</a>
          <span style="margin: 0 0.5rem; color: rgba(240,235,225,0.25);">/</span>
          <a href="/ai-automation" class="hover:text-text transition-colors duration-200">AI Automation</a>
          <span style="margin: 0 0.5rem; color: rgba(240,235,225,0.25);">/</span>
          AI Automation Systems
        </p>

        <h1
          class="font-display font-extrabold text-text tracking-tighter leading-none reveal"
          style="font-size: clamp(3rem, 6.5vw, 6.5rem); max-width: 18ch; margin-bottom: 2rem;"
        >
          AI Automation Systems for Kansas City Businesses Ready to Scale
        </h1>

        <p class="font-body text-text-muted reveal" style="font-size: 1.125rem; max-width: 52ch; margin-bottom: 2rem; line-height: 1.6;">
          If your team is manually following up on leads, building reports, or booking appointments, that's not a people problem. That's an automation problem. Dominion.Digital builds the fix.
        </p>

        <div class="flex flex-wrap items-center gap-4 reveal">
          <button
            type="button"
            data-open-contact
            class="btn-cta inline-flex items-center font-label font-semibold tracking-widest uppercase text-text bg-accent hover:bg-accent-hover active:scale-[0.97] transition-all duration-200"
            style="font-size: 0.7rem; padding: 0.6rem 1.25rem;"
          >
            Show Me What to Automate
          </button>
          <a
            href="/web-design/custom-web-development"
            class="inline-flex items-center font-label font-semibold tracking-widest uppercase text-text hover:text-accent transition-colors duration-200"
            style="font-size: 0.7rem; padding: 0.6rem 1.25rem; border: 1px solid rgba(240,235,225,0.25); border-radius: 9999px;"
            id="hero-ghost-secondary"
          >
            See Custom Development
          </a>
        </div>

      </div>
    </section>


    <!-- ─── OPENING / PUNCHLINE ───────────────────────────────────────────── -->
    <!-- Pattern A: 3fr/2fr split — narrative left, punchline card right -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem);"
      aria-labelledby="opening-punchline"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[3fr_2fr] items-start gap-16 md:gap-24" id="opening-block">

          <!-- Left: narrative -->
          <div>
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
              AI Automation / Systems
            </p>
            <div class="space-y-6" style="max-width: 60ch;">
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
                Every hour your team spends on manual follow-ups, copy-paste reporting, and repetitive scheduling is an hour not spent on the work that actually grows the business. The problem isn't the people. It's that the system was never built to handle it any other way.
              </p>
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
                AI automation systems replace the manual layer with workflows that run on their own. A lead comes in, they get a response in minutes. An appointment gets booked, your CRM updates automatically. A report that used to take an hour gets generated and delivered while you sleep.
              </p>
              <p class="font-body leading-relaxed text-text" style="font-size: 1.125rem;">
                Dominion.Digital builds custom AI automation for Kansas City businesses that are done trading time for revenue. Every workflow is built around your specific tools, your process, and the outcome you actually need.
              </p>
            </div>
          </div>

          <!-- Right: punchline card -->
          <div class="reveal" id="punchline-card" style="margin-top: 2rem;">
            <div style="border: 1px solid rgba(200,81,26,0.25); padding: clamp(2rem, 4vw, 3rem); position: relative; overflow: hidden;">
              <div aria-hidden="true" style="position: absolute; inset: 0; pointer-events: none; background: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(200,81,26,0.06) 0%, transparent 70%);"></div>
              <p class="font-label text-xs tracking-widest uppercase mb-6" style="color: #8a8880;">
                The Principle
              </p>
              <p
                class="font-display font-bold tracking-tight text-text"
                id="opening-punchline"
                style="font-size: clamp(1.5rem, 2.5vw, 2rem); line-height: 1.2;"
              >
                Your business should run while you're not watching it.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- ─── WHAT'S INCLUDED ───────────────────────────────────────────────── -->
    <!-- Pattern A flipped: 2fr/3fr — pills left, bento list right, surface bg -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem); background: #161614;"
      aria-labelledby="includes-heading"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[2fr_3fr] items-start gap-16 md:gap-24" id="includes-block">

          <!-- Left: label + pills -->
          <div>
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
              What's Included
            </p>
            <h2
              id="includes-heading"
              class="font-display font-bold tracking-tight text-text"
              style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 2rem; line-height: 1.1;"
            >
              Workflows That<br />Run Themselves.
            </h2>

            <!-- Pill cluster: Rapid Fire Benefits -->
            <div class="stagger" style="display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 2.5rem;" aria-label="Automation capabilities">
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Lead Follow-Up</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Appointment Booking</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">CRM Integration</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Reporting Pipelines</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Content Workflows</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Custom AI Workflows</span>
            </div>

            <!-- Trust anchor -->
            <div style="border-top: 1px solid rgba(200,81,26,0.2); padding-top: 1.5rem;">
              <p class="font-label text-xs tracking-widest uppercase" style="color: #c8511a; margin-bottom: 0.75rem;">
                Keeps Your Stack
              </p>
              <p class="font-body text-text-muted" style="font-size: 1rem; line-height: 1.6;">
                Dominion.Digital builds around what you already use. You keep your CRM, your calendar, your tools. We build the logic that connects them.
              </p>
            </div>

          </div>

          <!-- Right: Bento Checkmarks — Scope / Inclusion List -->
          <div>
            <ul class="stagger space-y-3" aria-label="What AI automation systems include">

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Lead follow-up automation</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Instant responses and multi-step nurture sequences that fire the moment a lead comes in</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Appointment booking</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Automated scheduling that syncs with your calendar and confirms without back-and-forth</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">CRM integration</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Contacts, deal stages, and notes updated automatically from form fills, calls, and bookings</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Reporting pipelines</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Scheduled reports built and delivered to your inbox without anyone manually pulling data</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Custom workflow design</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Every automation mapped to your actual process, not adapted from a generic template</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Handoff documentation</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Your team knows exactly how each system works and how to adjust it after delivery</p>
                </div>
              </li>

            </ul>
          </div>

        </div>
      </div>
    </section>


    <!-- ─── WHY IT MATTERS ────────────────────────────────────────────────── -->
    <!-- Pattern A: punchline callout left, narrative right -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem);"
      aria-labelledby="matters-heading"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[2fr_3fr] items-start gap-16 md:gap-24" id="matters-block">

          <!-- Left: stat callout -->
          <div>
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
              The Cost of Manual
            </p>
            <p
              class="font-display font-bold tracking-tighter text-accent"
              style="font-size: clamp(3rem, 6vw, 5.5rem); line-height: 0.9; margin-bottom: 1rem;"
            >
              5 min.
            </p>
            <p class="font-body text-text-muted" style="font-size: 1rem; max-width: 28ch; line-height: 1.5;">
              That's the window. After five minutes, the odds of reaching a new lead drop by 10x. Most businesses respond in hours.
            </p>
          </div>

          <!-- Right: narrative -->
          <div>
            <h2
              id="matters-heading"
              class="font-display font-bold tracking-tight text-text"
              style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 2rem; line-height: 1.1;"
            >
              The Leads You're Losing Aren't Gone. They Went to Whoever Responded First.
            </h2>
            <div class="space-y-6" style="max-width: 58ch;">
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
                The average business responds to new leads within a few hours on a good day. Studies consistently show that the odds of reaching a lead drop by 10x after the first five minutes. That gap costs real revenue, and most of it is invisible because no one tracks the leads that went cold before anyone called.
              </p>
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
                Automation closes that gap permanently. A system that responds in 90 seconds, every time, regardless of what else is happening in the business. The same applies to reporting, scheduling, and any other workflow your team does on repeat. When those tasks run themselves, your team's time goes toward things that can't be automated.
              </p>
              <p class="font-body leading-relaxed text-text" style="font-size: 1.125rem; font-weight: 500;">
                The leads you're losing aren't going somewhere. They're going to whoever responded first.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- ─── HOW WE APPROACH IT ────────────────────────────────────────────── -->
    <!-- Pattern E: Sticky sidecar, surface bg -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem); background: #161614;"
      aria-labelledby="process-heading"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[2fr_3fr] items-start gap-16 md:gap-24" id="process-block">

          <!-- Left: sticky label + heading -->
          <div class="md:sticky" style="top: 6rem;">
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
              The Process
            </p>
            <h2
              id="process-heading"
              class="font-display font-bold tracking-tight text-text"
              style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 1.5rem; line-height: 1.1;"
            >
              Audit First. Build What Matters.
            </h2>
            <p class="font-body text-text-muted" style="font-size: 1rem; max-width: 32ch; line-height: 1.6;">
              Every Dominion.Digital automation project starts with a workflow audit. What's eating your team's time? Where are leads falling through? That's where we start.
            </p>
          </div>

          <!-- Right: process steps -->
          <div>
            <ul class="stagger" aria-label="AI automation systems process">

              <li class="py-6" style="border-top: 1px solid rgba(240,235,225,0.08);">
                <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
                  <span class="font-label font-bold" style="color: #c8511a; font-size: 0.75rem; margin-top: 0.2rem; flex-shrink: 0;">01</span>
                  <div>
                    <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem;">Workflow audit</p>
                    <p class="font-body text-text-muted" style="font-size: 0.95rem; line-height: 1.6;">We identify every repetitive task and manual handoff in your business. Then we rank them by time cost and revenue impact to find the highest-value automations first.</p>
                  </div>
                </div>
              </li>

              <li class="py-6" style="border-top: 1px solid rgba(240,235,225,0.08);">
                <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
                  <span class="font-label font-bold" style="color: #c8511a; font-size: 0.75rem; margin-top: 0.2rem; flex-shrink: 0;">02</span>
                  <div>
                    <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem;">Automation logic mapping</p>
                    <p class="font-body text-text-muted" style="font-size: 0.95rem; line-height: 1.6;">Before building anything, Dominion.Digital maps every trigger, condition, and integration. Which event fires the workflow, what routes it differently, where it connects to your existing tools.</p>
                  </div>
                </div>
              </li>

              <li class="py-6" style="border-top: 1px solid rgba(240,235,225,0.08);">
                <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
                  <span class="font-label font-bold" style="color: #c8511a; font-size: 0.75rem; margin-top: 0.2rem; flex-shrink: 0;">03</span>
                  <div>
                    <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem;">Integration setup</p>
                    <p class="font-body text-text-muted" style="font-size: 0.95rem; line-height: 1.6;">We connect your CRM, calendar, forms, and any other tools involved. Everything runs through your existing stack so there's no platform migration required.</p>
                  </div>
                </div>
              </li>

              <li class="py-6" style="border-top: 1px solid rgba(240,235,225,0.08);">
                <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
                  <span class="font-label font-bold" style="color: #c8511a; font-size: 0.75rem; margin-top: 0.2rem; flex-shrink: 0;">04</span>
                  <div>
                    <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem;">End-to-end testing</p>
                    <p class="font-body text-text-muted" style="font-size: 0.95rem; line-height: 1.6;">Every workflow is tested with real data before it goes live. We run through every trigger condition and edge case until the system behaves exactly as designed.</p>
                  </div>
                </div>
              </li>

