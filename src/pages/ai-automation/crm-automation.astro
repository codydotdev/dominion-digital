  .faq-body-inner { padding-bottom: 1.5rem; }
  @keyframes faq-spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  .faq-icon { animation: faq-spin 4s linear infinite; }
  .faq-icon.is-open { animation: none; transform: rotate(180deg); }
</style>

<script>
  const revealIds = ['opening-block','punchline-card','includes-block','matters-block','process-block','faq-content','related-block','cta-block'];
  revealIds.forEach((id) => {
    const el = document.getElementById(id);
    if (!el || !el.classList.contains('reveal')) return;
    const obs = new IntersectionObserver(([e]) => { if (e.isIntersecting) { el.classList.add('visible'); obs.disconnect(); } }, { threshold: 0.08 });
    obs.observe(el);
  });
  document.querySelectorAll('.reveal').forEach((el) => {
    if (el.classList.contains('visible')) return;
    const obs = new IntersectionObserver(([e]) => { if (e.isIntersecting) { el.classList.add('visible'); obs.disconnect(); } }, { threshold: 0.08 });
    obs.observe(el);
  });
  document.querySelectorAll('.faq-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item')!;
      const body = item.querySelector('.faq-body') as HTMLElement;
      const icon = trigger.querySelector('.faq-icon') as HTMLElement;
      const isOpen = trigger.getAttribute('aria-expanded') === 'true';
      body.classList.toggle('is-open', !isOpen);
      icon.classList.toggle('is-open', !isOpen);
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });
  });
  const g = document.getElementById('hero-ghost-secondary');
  if (g) { g.addEventListener('mouseenter', () => { g.style.borderColor = '#c8511a'; }); g.addEventListener('mouseleave', () => { g.style.borderColor = 'rgba(240,235,225,0.25)'; }); }
  const c = document.getElementById('cta-ghost');
  if (c) { c.addEventListener('mouseenter', () => { c.style.borderColor = '#c8511a'; }); c.addEventListener('mouseleave', () => { c.style.borderColor = 'rgba(240,235,225,0.25)'; }); }
</script>
