---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import FloatingPaths from '../../components/FloatingPaths.astro';
---

<Layout
  title="Generative Engine Optimization (GEO) | Dominion.Digital"
  description="Get your Kansas City business cited by ChatGPT, Perplexity, and Google AI Overviews. Dominion.Digital builds the content that earns AI citations and positions your business as the answer."
  canonicalUrl="https://dominion.digital/internet-marketing/geo"
>
  <Fragment slot="head">
    <script type="application/ld+json">
    [
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://dominion.digital"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Internet Marketing",
            "item": "https://dominion.digital/internet-marketing"
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": "Generative Engine Optimization",
            "item": "https://dominion.digital/internet-marketing/geo"
          }
        ]
      },
      {
        "@context": "https://schema.org",
        "@type": "Service",
        "@id": "https://dominion.digital/internet-marketing/geo#service",
        "name": "Generative Engine Optimization",
        "serviceType": "Generative Engine Optimization",
        "provider": {
          "@type": "Organization",
          "@id": "https://dominion.digital/#organization",
          "name": "Dominion.Digital"
        },
        "areaServed": {
          "@type": "City",
          "name": "Kansas City",
          "addressRegion": "MO"
        },
        "url": "https://dominion.digital/internet-marketing/geo"
      },
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "What is GEO and how is it different from SEO?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "SEO is about ranking in traditional search results. GEO is about getting cited by AI tools like ChatGPT, Perplexity, and Google AI Overviews when they answer questions directly. The two overlap: content that ranks well in Google tends to be cited more by AI tools. GEO adds a layer of structure and formatting on top of SEO to make your content easy for AI systems to extract and quote."
            }
          },
          {
            "@type": "Question",
            "name": "Which AI platforms does GEO cover?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Dominion.Digital tracks and optimizes for the platforms your customers are most likely using: Google AI Overviews, ChatGPT, and Perplexity. Coverage expands as new platforms gain adoption. The content and structure work done for one platform generally carries over to others."
            }
          },
          {
            "@type": "Question",
            "name": "Does my business need both SEO and GEO?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "For most Kansas City businesses, yes. SEO covers traditional Google rankings. GEO covers AI search. Dominion.Digital runs them together because the content strategy is shared. Doing both at once is more efficient than treating them as separate projects."
            }
          }
        ]
      }
    ]
    </script>
  </Fragment>

  <Nav />

  <main>

    <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
    <section
      class="relative"
      style="padding-top: clamp(9rem, 18vw, 14rem); padding-bottom: clamp(5rem, 10vw, 8rem);"
      aria-label="GEO Services hero"
    >
      <FloatingPaths />
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(200,81,26,0.07) 0%, transparent 70%); z-index: 0;"
        aria-hidden="true"
      ></div>

      <div class="container relative" style="z-index: 1;">

        <!-- Breadcrumb -->
        <p class="font-label text-xs tracking-widest uppercase mb-6 reveal" style="color: #8a8880;">
          <a href="/" class="hover:text-text transition-colors duration-200">Home</a>
          <span style="margin: 0 0.5rem; color: rgba(240,235,225,0.25);">/</span>
          <a href="/internet-marketing" class="hover:text-text transition-colors duration-200">Internet Marketing</a>
          <span style="margin: 0 0.5rem; color: rgba(240,235,225,0.25);">/</span>
          GEO
        </p>

        <h1
          class="font-display font-extrabold text-text tracking-tighter leading-none reveal"
          style="font-size: clamp(3rem, 6.5vw, 6.5rem); max-width: 18ch; margin-bottom: 2rem;"
        >
          Get Your Kansas City Business Cited by ChatGPT, Perplexity, and Google AI Overviews
        </h1>

        <p class="font-body text-text-muted reveal" style="font-size: 1.125rem; max-width: 52ch; margin-bottom: 2rem; line-height: 1.6;">
          ChatGPT, Perplexity, and Google's AI Overviews now answer your customers' questions directly. The business they cite gets the lead. Dominion.Digital builds the content that earns the citation.
        </p>

        <div class="flex flex-wrap items-center gap-4 reveal">
          <button
            type="button"
            data-open-contact
            class="btn-cta inline-flex items-center font-label font-semibold tracking-widest uppercase text-text bg-accent hover:bg-accent-hover active:scale-[0.97] transition-all duration-200"
            style="font-size: 0.7rem; padding: 0.6rem 1.25rem;"
          >
            Get a Free GEO Audit
          </button>
          <a
            href="/internet-marketing/seo"
            class="inline-flex items-center font-label font-semibold tracking-widest uppercase text-text hover:text-accent transition-colors duration-200"
            style="font-size: 0.7rem; padding: 0.6rem 1.25rem; border: 1px solid rgba(240,235,225,0.25); border-radius: 9999px;"
            id="hero-ghost-secondary"
          >
            See SEO Services
          </a>
        </div>

      </div>
    </section>


    <!-- ─── OPENING / PUNCHLINE ───────────────────────────────────────────── -->
    <!-- Pattern A: 3fr/2fr split — narrative left, punchline card right -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem);"
      aria-labelledby="opening-punchline"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[3fr_2fr] items-start gap-16 md:gap-24" id="opening-block">

          <!-- Left: narrative -->
          <div>
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
              Internet Marketing / GEO
            </p>
            <div class="space-y-6" style="max-width: 60ch;">
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
                The way people search has changed. A growing share of searches now end without a click. Instead of scrolling through results, people ask ChatGPT, Perplexity, or Google's AI Overviews a question and get a direct answer back. That answer cites a source. Sometimes it recommends a specific business.
              </p>
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
                Generative Engine Optimization is the practice of structuring your content so that AI systems choose your business as the source they cite. Very few internet marketing service providers in Kansas City are doing it at all. That gap is an opportunity right now.
              </p>
              <p class="font-body leading-relaxed text-text" style="font-size: 1.125rem;">
                Dominion.Digital builds content that satisfies both Google's traditional ranking signals and the trust criteria AI systems use to decide who to quote. The same work compounds across both channels.
              </p>
            </div>
          </div>

          <!-- Right: punchline card -->
          <div class="reveal" id="punchline-card" style="margin-top: 2rem;">
            <div style="border: 1px solid rgba(200,81,26,0.25); padding: clamp(2rem, 4vw, 3rem); position: relative; overflow: hidden;">
              <div aria-hidden="true" style="position: absolute; inset: 0; pointer-events: none; background: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(200,81,26,0.06) 0%, transparent 70%);"></div>
              <p class="font-label text-xs tracking-widest uppercase mb-6" style="color: #8a8880;">
                The Principle
              </p>
              <p
                class="font-display font-bold tracking-tight text-text"
                id="opening-punchline"
                style="font-size: clamp(1.5rem, 2.5vw, 2rem); line-height: 1.2;"
              >
                When someone asks an AI tool who to call in Kansas City, your business should be the answer it gives.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- ─── WHAT'S INCLUDED ───────────────────────────────────────────────── -->
    <!-- Pattern A flipped: 2fr/3fr — pills left, bento list right, surface bg -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem); background: #161614;"
      aria-labelledby="includes-heading"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[2fr_3fr] items-start gap-16 md:gap-24" id="includes-block">

          <!-- Left: label + pills -->
          <div>
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
              What's Included
            </p>
            <h2
              id="includes-heading"
              class="font-display font-bold tracking-tight text-text"
              style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 2rem; line-height: 1.1;"
            >
              Content AI<br />Systems Trust.
            </h2>

            <!-- Pill cluster: Rapid Fire Benefits -->
            <div class="stagger" style="display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 2.5rem;" aria-label="GEO capabilities">
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">AI Search Visibility Audit</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Structured Content for Citation</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">E-E-A-T Authority Building</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">FAQ &amp; Q&amp;A Optimization</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">AI-Ready Schema Markup</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Monthly Citation Monitoring</span>
            </div>

            <!-- Trust anchor -->
            <div style="border-top: 1px solid rgba(200,81,26,0.2); padding-top: 1.5rem;">
              <p class="font-label text-xs tracking-widest uppercase" style="color: #c8511a; margin-bottom: 0.75rem;">
                Works Alongside SEO
              </p>
              <p class="font-body text-text-muted" style="font-size: 1rem; line-height: 1.6;">
                GEO and SEO share the same content foundation. Pages built for AI citation rank better in traditional search too. Dominion.Digital runs both together so the work serves both channels.
              </p>
            </div>
          </div>

          <!-- Right: Bento Checkmarks — Scope / Inclusion List -->
          <div>
            <ul class="stagger space-y-3" aria-label="What GEO includes">

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">AI visibility audit</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Review of how your business appears in ChatGPT, Perplexity, and Google AI Overviews, and where citations are currently going to competitors</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Structured content writing</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Q&amp;A-formatted, citation-ready content built around the questions your customers ask AI tools</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">E-E-A-T authority signals</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Experience, expertise, authoritativeness, and trust indicators built into page structure, author context, and supporting content</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">FAQ and conversational content</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Direct-answer formatting that matches how AI tools extract and quote information from your pages</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Schema markup</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">FAQ, HowTo, and Organization schema implemented to give AI systems clean, structured data to cite</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Monthly citation monitoring</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Tracking where and how often your business appears in AI-generated answers across major platforms</p>
                </div>
              </li>

            </ul>
          </div>

        </div>
      </div>
    </section>


    <!-- ─── WHY IT MATTERS ────────────────────────────────────────────────── -->
    <!-- Pattern A: stat callout left, narrative right -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem);"
      aria-labelledby="matters-heading"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[2fr_3fr] items-start gap-16 md:gap-24" id="matters-block">

          <!-- Left: stat callout -->
          <div>
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
              The Shift
            </p>
            <p
              class="font-display font-bold tracking-tighter text-accent"
              style="font-size: clamp(3rem, 6vw, 5.5rem); line-height: 0.9; margin-bottom: 1rem;"
            >
              Zero<br />Click.
            </p>
            <p class="font-body text-text-muted" style="font-size: 1rem; max-width: 28ch; line-height: 1.5;">
              A growing share of searches end inside the AI tool. The website never gets visited. The business that gets cited wins the customer.
            </p>
          </div>

          <!-- Right: narrative -->
          <div>
            <h2
              id="matters-heading"
              class="font-display font-bold tracking-tight text-text"
              style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 2rem; line-height: 1.1;"
            >
              Most Kansas City Businesses Are Invisible in AI Search Right Now.
            </h2>
            <div class="space-y-6" style="max-width: 58ch;">
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
                Most businesses have a Google Business Profile, rank somewhere in traditional search, and have no presence in AI-generated answers at all. The businesses investing in GEO now will be the default recommendation AI tools give for their category when the market catches up.
              </p>
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
                AI tools build their answers from a small set of trusted, well-structured sources. They cite the content that answers the question clearly, comes from an authoritative source, and is formatted in a way they can extract. Thin pages and unstructured copy don't make the cut.
              </p>
              <p class="font-body leading-relaxed text-text" style="font-size: 1.125rem; font-weight: 500;">
                Getting cited by AI tools comes from building content they know how to use. That's what Dominion.Digital builds.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- ─── HOW WE APPROACH IT ────────────────────────────────────────────── -->
    <!-- Pattern E: Sticky sidecar, surface bg -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem); background: #161614;"
      aria-labelledby="process-heading"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[2fr_3fr] items-start gap-16 md:gap-24" id="process-block">

          <!-- Left: sticky label + heading -->
          <div class="md:sticky" style="top: 6rem;">
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
              The Process
            </p>
            <h2
              id="process-heading"
              class="font-display font-bold tracking-tight text-text"
              style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 1.5rem; line-height: 1.1;"
            >
              Audit First. Build What Gets Cited.
            </h2>
            <p class="font-body text-text-muted" style="font-size: 1rem; max-width: 32ch; line-height: 1.6;">
              Every GEO engagement starts with a full audit of your current AI search presence. Dominion.Digital runs your category through the major AI platforms and documents where citations are going and why.
            </p>
          </div>

          <!-- Right: process steps -->
          <div>
            <ul class="stagger" aria-label="GEO process steps">

              <li class="py-6" style="border-top: 1px solid rgba(240,235,225,0.08);">
                <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
                  <span class="font-label font-bold" style="color: #c8511a; font-size: 0.75rem; margin-top: 0.2rem; flex-shrink: 0;">01</span>
                  <div>
                    <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem;">AI visibility audit</p>
                    <p class="font-body text-text-muted" style="font-size: 0.95rem; line-height: 1.6;">Your business category and primary services are run through ChatGPT, Perplexity, and Google AI Overviews. Dominion.Digital documents every citation, who's getting recommended, and what content is earning it.</p>
                  </div>
                </div>
              </li>

              <li class="py-6" style="border-top: 1px solid rgba(240,235,225,0.08);">
                <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
                  <span class="font-label font-bold" style="color: #c8511a; font-size: 0.75rem; margin-top: 0.2rem; flex-shrink: 0;">02</span>
                  <div>
                    <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem;">Citation gap analysis</p>
                    <p class="font-body text-text-muted" style="font-size: 0.95rem; line-height: 1.6;">Dominion.Digital identifies which questions your customers are asking AI tools, which competitors are being cited in response, and what structure and authority signals those pages have that yours don't yet.</p>
                  </div>
                </div>
              </li>

              <li class="py-6" style="border-top: 1px solid rgba(240,235,225,0.08);">
                <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
                  <span class="font-label font-bold" style="color: #c8511a; font-size: 0.75rem; margin-top: 0.2rem; flex-shrink: 0;">03</span>
                  <div>
                    <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem;">Content and page restructuring</p>
                    <p class="font-body text-text-muted" style="font-size: 0.95rem; line-height: 1.6;">New citation-ready content is built around the questions your customers ask. Existing pages are restructured so AI systems can extract and use them. Both tracks run in parallel.</p>
                  </div>
                </div>
              </li>

              <li class="py-6" style="border-top: 1px solid rgba(240,235,225,0.08);">
                <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
                  <span class="font-label font-bold" style="color: #c8511a; font-size: 0.75rem; margin-top: 0.2rem; flex-shrink: 0;">04</span>
                  <div>
                    <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem;">Schema markup implementation</p>
