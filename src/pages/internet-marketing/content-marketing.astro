---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import FloatingPaths from '../../components/FloatingPaths.astro';
---

<Layout
  title="Content Marketing Kansas City | Dominion.Digital"
  description="Content marketing for Kansas City businesses. Keyword-driven blog writing, topical authority clusters, and AI-citation-ready content that earns traffic and builds long-term search presence."
  canonicalUrl="https://dominion.digital/internet-marketing/content-marketing"
>
  <Fragment slot="head">
    <script type="application/ld+json">
    [
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://dominion.digital"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Internet Marketing",
            "item": "https://dominion.digital/internet-marketing"
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": "Content Marketing",
            "item": "https://dominion.digital/internet-marketing/content-marketing"
          }
        ]
      },
      {
        "@context": "https://schema.org",
        "@type": "Service",
        "@id": "https://dominion.digital/internet-marketing/content-marketing#service",
        "name": "Content Marketing",
        "serviceType": "Content Marketing",
        "provider": {
          "@type": "Organization",
          "@id": "https://dominion.digital/#organization",
          "name": "Dominion.Digital"
        },
        "areaServed": {
          "@type": "City",
          "name": "Kansas City",
          "addressRegion": "MO"
        },
        "url": "https://dominion.digital/internet-marketing/content-marketing"
      },
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "How long does it take for content to start ranking?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "New content typically starts picking up impressions within a few weeks of publishing and gains ranking momentum over the following months as Google indexes and evaluates it. Topical clusters tend to accelerate this: once Google recognizes your site as an authority on a subject, new pieces in that cluster rank faster."
            }
          },
          {
            "@type": "Question",
            "name": "How much content do I need?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "It depends on your market and your goals. Dominion.Digital starts with a keyword research session to identify the highest-value opportunities and builds a content plan from there. Most Kansas City businesses start with one to two pieces per month and scale up as results compound."
            }
          },
          {
            "@type": "Question",
            "name": "Do I need a separate content strategy for GEO?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "The same content serves both. Dominion.Digital structures every piece to rank in Google and to be cited by AI tools like ChatGPT and Perplexity. FAQ sections, direct-answer formatting, and schema markup are built into every article from the start."
            }
          }
        ]
      }
    ]
    </script>
  </Fragment>

  <Nav />

  <main>

    <!-- ─── HERO ──────────────────────────────────────────────────────────── -->
    <section
      class="relative"
      style="padding-top: clamp(9rem, 18vw, 14rem); padding-bottom: clamp(5rem, 10vw, 8rem);"
      aria-label="Content Marketing hero"
    >
      <FloatingPaths />
      <div
        class="absolute inset-0 pointer-events-none"
        style="background: radial-gradient(ellipse 60% 50% at 50% 0%, rgba(200,81,26,0.07) 0%, transparent 70%); z-index: 0;"
        aria-hidden="true"
      ></div>

      <div class="container relative" style="z-index: 1;">

        <!-- Breadcrumb -->
        <p class="font-label text-xs tracking-widest uppercase mb-6 reveal" style="color: #8a8880;">
          <a href="/" class="hover:text-text transition-colors duration-200">Home</a>
          <span style="margin: 0 0.5rem; color: rgba(240,235,225,0.25);">/</span>
          <a href="/internet-marketing" class="hover:text-text transition-colors duration-200">Internet Marketing</a>
          <span style="margin: 0 0.5rem; color: rgba(240,235,225,0.25);">/</span>
          Content Marketing
        </p>

        <h1
          class="font-display font-extrabold text-text tracking-tighter leading-none reveal"
          style="font-size: clamp(3rem, 6.5vw, 6.5rem); max-width: 18ch; margin-bottom: 2rem;"
        >
          Kansas City Content Marketing That Earns Traffic Instead of Buying It
        </h1>

        <p class="font-body text-text-muted reveal" style="font-size: 1.125rem; max-width: 52ch; margin-bottom: 2rem; line-height: 1.6;">
          Every blog post and guide is an asset that compounds over time. <strong style="font-weight: 800; color: #f0ebe1;">Dominion</strong><span style="color: #c8511a;">.</span><span style="font-weight: 400; color: #f0ebe1;">Digital</span> builds content strategies around keywords your customers search and topics AI tools actually cite.
        </p>

        <div class="flex flex-wrap items-center gap-4 reveal">
          <button
            type="button"
            data-open-contact
            class="btn-cta inline-flex items-center font-label font-semibold tracking-widest uppercase text-text bg-accent hover:bg-accent-hover active:scale-[0.97] transition-all duration-200"
            style="font-size: 0.7rem; padding: 0.6rem 1.25rem;"
          >
            Get a Content Strategy Call
          </button>
          <a
            href="/internet-marketing/seo"
            class="inline-flex items-center font-label font-semibold tracking-widest uppercase text-text hover:text-accent transition-colors duration-200"
            style="font-size: 0.7rem; padding: 0.6rem 1.25rem; border: 1px solid rgba(240,235,225,0.25); border-radius: 9999px;"
            id="hero-ghost-secondary"
          >
            See SEO Services
          </a>
        </div>

      </div>
    </section>


    <!-- ─── OPENING / PUNCHLINE ───────────────────────────────────────────── -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem);"
      aria-labelledby="opening-punchline"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[3fr_2fr] items-start gap-16 md:gap-24" id="opening-block">

          <!-- Left: narrative -->
          <div>
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
              Internet Marketing / Content
            </p>
            <div class="space-y-6" style="max-width: 60ch;">
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
                Most Kansas City businesses publish content that nobody reads. A blog post goes up, gets no traffic, and sits there doing nothing. That happens when content is written without a strategy: no keyword research, no topical structure, no connection to what customers are actually searching for.
              </p>
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
                Content marketing as an internet marketing service works differently when it's built around a plan. Every piece targets a specific search query, fits into a topical cluster that builds authority on a subject, and is structured to be cited by both Google and AI tools like ChatGPT and Perplexity.
              </p>
              <p class="font-body leading-relaxed text-text" style="font-size: 1.125rem;">
                <strong style="font-weight: 800; color: #f0ebe1;">Dominion</strong><span style="color: #c8511a;">.</span><span style="font-weight: 400; color: #f0ebe1;">Digital</span> builds content strategies for Kansas City businesses that want to own their category in search, earn traffic without paying for every click, and become the go-to source in their market.
              </p>
            </div>
          </div>

          <!-- Right: punchline card -->
          <div class="reveal" id="punchline-card" style="margin-top: 2rem;">
            <div style="border: 1px solid rgba(200,81,26,0.25); padding: clamp(2rem, 4vw, 3rem); position: relative; overflow: hidden;">
              <div aria-hidden="true" style="position: absolute; inset: 0; pointer-events: none; background: radial-gradient(ellipse 80% 80% at 50% 50%, rgba(200,81,26,0.06) 0%, transparent 70%);"></div>
              <p class="font-label text-xs tracking-widest uppercase mb-6" style="color: #8a8880;">
                The Principle
              </p>
              <p
                class="font-display font-bold tracking-tight text-text"
                id="opening-punchline"
                style="font-size: clamp(1.5rem, 2.5vw, 2rem); line-height: 1.2;"
              >
                A blog post written to rank is a lead source that pays you back every month without additional spend.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- ─── WHAT'S INCLUDED ───────────────────────────────────────────────── -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem); background: #161614;"
      aria-labelledby="includes-heading"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[2fr_3fr] items-start gap-16 md:gap-24" id="includes-block">

          <!-- Left: label + pills + trust anchor -->
          <div>
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
              What's Included
            </p>
            <h2
              id="includes-heading"
              class="font-display font-bold tracking-tight text-text"
              style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 2rem; line-height: 1.1;"
            >
              Content That<br />Earns Its Place.
            </h2>

            <div class="stagger" style="display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 2.5rem;" aria-label="Content marketing capabilities">
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Keyword Research &amp; Mapping</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Topical Authority Clusters</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">SEO-Optimized Blog Writing</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,224,0.15); border-radius: 9999px;">AI Citation Formatting</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Internal Linking Strategy</span>
              <span class="font-label tracking-widest uppercase text-text" style="font-size: 0.65rem; padding: 0.5rem 1rem; border: 1px solid rgba(240,235,225,0.15); border-radius: 9999px;">Monthly Performance Reporting</span>
            </div>

            <div style="border-top: 1px solid rgba(200,81,26,0.2); padding-top: 1.5rem;">
              <p class="font-label text-xs tracking-widest uppercase" style="color: #c8511a; margin-bottom: 0.75rem;">
                Built for Google and AI Search
              </p>
              <p class="font-body text-text-muted" style="font-size: 1rem; line-height: 1.6;">
                Every article is structured to rank in traditional search and be cited by AI tools. FAQ sections, schema markup, and direct-answer formatting are included in every piece.
              </p>
            </div>
          </div>

          <!-- Right: Bento Checkmarks -->
          <div>
            <ul class="stagger space-y-3" aria-label="What content marketing includes">

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Keyword research and mapping</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Identifying the specific terms your customers search and mapping them to content opportunities across your site</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Topical authority clusters</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Content organized into pillar pages and supporting articles that signal deep expertise to Google on a specific subject</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">SEO-optimized blog writing</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Articles written to rank, structured with proper headers, keyword placement, and internal links built in from the start</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">AI citation formatting</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Direct-answer formatting, FAQ sections, and schema markup so AI tools can extract and cite your content</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Internal linking strategy</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Every new piece connects to relevant service pages and existing content, distributing authority across your site</p>
                </div>
              </li>

              <li style="display: flex; align-items: flex-start; gap: 1rem; padding: 1.5rem 2rem; background: rgba(13,13,11,0.6); border: 1px solid rgba(240,235,225,0.07);">
                <svg style="flex-shrink: 0; margin-top: 0.15rem; width: 1.1rem; height: 1.1rem; color: #c8511a;" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                <div>
                  <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.25rem;">Monthly performance reporting</p>
                  <p class="font-body text-text-muted" style="font-size: 0.9rem; line-height: 1.5;">Traffic, rankings, and engagement tracked for every published piece and reported monthly</p>
                </div>
              </li>

            </ul>
          </div>

        </div>
      </div>
    </section>


    <!-- ─── WHY IT MATTERS ────────────────────────────────────────────────── -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem);"
      aria-labelledby="matters-heading"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[2fr_3fr] items-start gap-16 md:gap-24" id="matters-block">

          <!-- Left: stat callout -->
          <div>
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
              The Case for Content
            </p>
            <p
              class="font-display font-bold tracking-tighter text-accent"
              style="font-size: clamp(3rem, 6vw, 5.5rem); line-height: 0.9; margin-bottom: 1rem;"
            >
              Ever&shy;green.
            </p>
            <p class="font-body text-text-muted" style="font-size: 1rem; max-width: 28ch; line-height: 1.5;">
              Content written to rank keeps delivering traffic and leads long after it's published. Every piece adds to a library that grows more valuable over time.
            </p>
          </div>

          <!-- Right: narrative -->
          <div>
            <h2
              id="matters-heading"
              class="font-display font-bold tracking-tight text-text"
              style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 2rem; line-height: 1.1;"
            >
              A Business With Deep Content Wins on Authority, Not Just Budget.
            </h2>
            <div class="space-y-6" style="max-width: 58ch;">
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
                For Kansas City businesses competing in crowded markets, topical authority is one of the clearest paths to ranking ahead of larger competitors. Google rewards sites that cover a subject in depth. A business with 30 well-structured articles on a topic will outrank a competitor with one thin page, even if the competitor has a bigger ad budget.
              </p>
              <p class="font-body leading-relaxed text-text-muted" style="font-size: 1.125rem;">
                The same content that ranks in Google also feeds GEO. AI tools cite the sources that answer questions clearly and come from sites that demonstrate authority. A strong content library serves both channels at the same time.
              </p>
              <p class="font-body leading-relaxed text-text" style="font-size: 1.125rem; font-weight: 500;">
                Every piece of content <strong style="font-weight: 800; color: #f0ebe1;">Dominion</strong><span style="color: #c8511a;">.</span><span style="font-weight: 400; color: #f0ebe1;">Digital</span> builds is working for you. Traffic, citations, rankings: all from a single well-written article.
              </p>
            </div>
          </div>

        </div>
      </div>
    </section>


    <!-- ─── HOW WE APPROACH IT ────────────────────────────────────────────── -->
    <section
      style="padding-top: clamp(6rem, 12vw, 10rem); padding-bottom: clamp(6rem, 12vw, 10rem); background: #161614;"
      aria-labelledby="process-heading"
    >
      <div class="container">
        <div class="reveal grid grid-cols-1 md:grid-cols-[2fr_3fr] items-start gap-16 md:gap-24" id="process-block">

          <!-- Left: sticky label + heading -->
          <div class="md:sticky" style="top: 6rem;">
            <p class="font-label text-xs tracking-widest uppercase mb-5" style="color: #8a8880;">
              The Process
            </p>
            <h2
              id="process-heading"
              class="font-display font-bold tracking-tight text-text"
              style="font-size: clamp(2rem, 4vw, 3rem); margin-bottom: 1.5rem; line-height: 1.1;"
            >
              Strategy First. Then Write.
            </h2>
            <p class="font-body text-text-muted" style="font-size: 1rem; max-width: 32ch; line-height: 1.6;">
              Every engagement starts with a content audit and keyword research session. What does your site already cover? Where are the gaps? Which topics are your customers searching that you aren't ranking for yet?
            </p>
          </div>

          <!-- Right: process steps -->
          <div>
            <ul class="stagger" aria-label="Content marketing process steps">

              <li class="py-6" style="border-top: 1px solid rgba(240,235,225,0.08);">
                <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
                  <span class="font-label font-bold" style="color: #c8511a; font-size: 0.75rem; margin-top: 0.2rem; flex-shrink: 0;">01</span>
                  <div>
                    <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem;">Content audit and keyword research</p>
                    <p class="font-body text-text-muted" style="font-size: 0.95rem; line-height: 1.6;">Your existing content is reviewed alongside a full keyword research pass. <strong style="font-weight: 800; color: #f0ebe1;">Dominion</strong><span style="color: #c8511a;">.</span><span style="font-weight: 400; color: #f0ebe1;">Digital</span> identifies what's already working, what's missing, and which topics your competitors rank for that represent the best opportunities.</p>
                  </div>
                </div>
              </li>

              <li class="py-6" style="border-top: 1px solid rgba(240,235,225,0.08);">
                <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
                  <span class="font-label font-bold" style="color: #c8511a; font-size: 0.75rem; margin-top: 0.2rem; flex-shrink: 0;">02</span>
                  <div>
                    <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem;">Topical cluster mapping</p>
                    <p class="font-body text-text-muted" style="font-size: 0.95rem; line-height: 1.6;">Content is organized into clusters: a pillar page for the broad topic and supporting articles for the specific questions underneath it. This structure is what signals authority to Google and AI tools alike.</p>
                  </div>
                </div>
              </li>

              <li class="py-6" style="border-top: 1px solid rgba(240,235,225,0.08);">
                <div style="display: flex; align-items: flex-start; gap: 1.25rem;">
                  <span class="font-label font-bold" style="color: #c8511a; font-size: 0.75rem; margin-top: 0.2rem; flex-shrink: 0;">03</span>
                  <div>
                    <p class="font-body text-text" style="font-size: 1rem; font-weight: 500; margin-bottom: 0.4rem;">Content writing and publishing</p>
                    <p class="font-body text-text-muted" style="font-size: 0.95rem; line-height: 1.6;"><strong style="font-weight: 800; color: #f0ebe1;">Dominion</strong><span style="color: #c8511a;">.</span><span style="font-weight: 400; color: #f0ebe1;">Digital</span> writes and publishes on a consistent cadence. Every article is optimized for search, formatted for AI citation, and connected to relevant service pages through internal links before it goes live.</p>
                  </div>
                </div>
              </li>

