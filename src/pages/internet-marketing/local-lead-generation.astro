        "@type": "FAQPage",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "How quickly will I start seeing leads?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Google Ads typically produces leads within the first week once campaigns go live. SEO takes longer to build momentum but compounds over time. Most Kansas City businesses see a meaningful increase in total lead volume within the first 60 days when both channels are running together."
            }
          },
          {
            "@type": "Question",
            "name": "How is this different from just running Google Ads on my own?",
