  canonicalUrl="https://dominion.digital/internet-marketing/local-lead-generation"
>
  <Fragment slot="head">
    <script type="application/ld+json">
    [
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          {
            "@type": "ListItem",
            "position": 1,
            "name": "Home",
            "item": "https://dominion.digital"
          },
          {
            "@type": "ListItem",
            "position": 2,
            "name": "Internet Marketing",
            "item": "https://dominion.digital/internet-marketing"
          },
          {
            "@type": "ListItem",
            "position": 3,
            "name": "Local Lead Generation",
            "item": "https://dominion.digital/internet-marketing/local-lead-generation"
          }
